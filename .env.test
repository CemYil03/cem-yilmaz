# Integration-test environment variables.
#
# Committed on purpose: points the test suite at a SEPARATE local database that
# it is free to truncate/mutate. Contains no secrets.
#
# Loaded by src/server/test/commandTestUtils.ts (via dotenv).
#
# IMPORTANT (Cursor Cloud): `dotenv` does NOT override an already-set
# process.env var. When the `DATABASE_URL` secret is injected it wins over the
# value below, which would point the suite at the shared remote DB. Run tests
# with the local URL forced, e.g.:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mydb_test" npm test
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mydb_test"

# Any non-empty string works for tests.
VISITOR_IP_HASH_SALT="test-salt"
