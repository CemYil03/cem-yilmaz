{
    "name": "cem-yilmaz",
    "private": true,
    "type": "module",
    "scripts": {
        "postinstall": "([ -z \"$CI\" ] && npm dedupe --quiet || true)",
        "check": "npm run format:check && npm run lint:check && npm run spell:check && npm run type:check && npm run usage:check && npm run commitlint:check",
        "commitlint:check": "commitlint --from HEAD~1 --to HEAD",
        "dev": "vite dev --port 3000",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "drizzle-kit generate && prettier --write drizzle/",
