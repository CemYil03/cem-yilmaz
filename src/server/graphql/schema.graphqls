scalar DateTime
scalar Date
# Untyped JSON payload — used only where the GraphQL schema is itself a union
# of values that the UI surfaces verbatim (e.g. tool call arguments rendered
# in a debug/inspect dialog). See docs/architecture/chat.md.
scalar JSON

type ChatMessageUser {
    chatMessageId: ID!
    # Null for anonymous visitor messages. The visitor surface never has a
    # `User` row to attach (anonymous traffic by design) — the client
    # renders "Du" / "You" when this is null. Admin chats always have a
    # logged-in author so the field is populated there.
    author: User
    body: String!
    # Files the user attached to this message, in send-order. Empty list when
    # the message was a plain-text send. The bytes are not exposed inline —
    # `FileUpload.url` points at `/api/file-uploads/:id` which streams them
    # back behind the same session cookie that authorized the upload.
    attachments: [FileUpload!]!
    # Observations the compass analyzer extracted from this user message.
    # Empty when the analyzer hasn't run yet, or ran and found nothing to
    # record. Populated only on admin (`scope = 'admin'`) chats — the
    # analyzer never runs on visitor messages. The UI uses this to render an
    # inline "N observations" pill below the message body. See
    # `docs/features/compass.md`.
    compassObservations: [CompassObservation!]!
    createdAt: DateTime!
}

# A persisted user-uploaded file. Consumer-agnostic — chat surfaces these
# today as message attachments via the `ChatMessageUser.attachments` field,
# but the same shape is reused by other surfaces (e.g. assistant-side
# outputs, avatars, document uploads).
type FileUpload {
    fileUploadId: ID!
    filename: String!
    # IANA media type — drives both the in-bubble preview (image vs file
    # chip) and the LLM-side `ImagePart` / `FilePart` choice in
    # `toModelMessages`.
    mediaType: String!
    # Size in bytes. Mirrors what the upload route persisted; clamped at the
    # route, not validated again here.
    size: Int!
    # Server-rooted URL to stream the bytes back. Today: `/api/file-uploads/:id`.
    url: String!
}

# Snapshot of a single LLM step's identity and token usage. Attached to every
# AI-produced message variant — see `docs/architecture/chat-persistence.md`
# ("Generation metadata"). The whole field is nullable on the parent variants
# because pre-feature rows have no usage and rare provider responses may omit
# the model id; when present, `modelId` is always populated. The token fields
# are individually nullable because providers vary (Gemini reports
# `cachedInputTokens`; OpenAI reports `reasoningTokens`; some omit
# `totalTokens` and the server falls back to `inputTokens + outputTokens`).
#
# A single LLM step can produce multiple message rows (text + N tool calls);
# each row carries the same snapshot, so naive `SUM(totalTokens)` aggregations
# over-count. Group by `(chatMessageId, step boundary)` for accurate totals.
type ChatMessageGeneration {
    modelId: String!
    inputTokens: Int
    outputTokens: Int
    totalTokens: Int
    reasoningTokens: Int
    cachedInputTokens: Int
}

type ChatMessageAssistantText {
    chatMessageId: ID!
    body: String!
    # Snapshot of the LLM step that produced this row. See `ChatMessageGeneration`.
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

type ChatMessageToolCall {
    chatMessageId: ID!
    toolName: String!
    # Per-tool-typed call arguments, exposed as opaque JSON so the UI can
    # render them in an inspect dialog. The shape is only validated at the
    # tool boundary by Zod.
    args: JSON!
    # When a sub-agent runs inside a parent tool's `execute` (today:
    # `delegateToProjects` running `agentPersonalAssistantProjects`), each
    # child tool call is persisted with `parentChatMessageId` set to the
    # parent delegate row's id. The transcript filters child rows out of the
    # top-level list and renders them indented under the parent's card. Null
    # for top-level tool calls. See `docs/architecture/agent-delegation.md`
    # ("Nested tool calls").
    parentChatMessageId: ID
    # The tool's return value, opaque JSON (same rationale as `args`). Null
    # while a call is still in flight or for tools that return void. The UI
    # reads a `{ status, summary }` convention when present (the `delegateTo*`
    # tools follow it) to drive the row's status indicator + inline summary,
    # and otherwise shows the raw JSON in the inspector. See docs/styles/chat.md.
    toolResult: JSON
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

type ChatMessageToolApprovalRequest {
    chatMessageId: ID!
    approvalId: String!
    toolName: String!
    # The pending call's arguments — same shape and rationale as
    # `ChatMessageToolCall.args`. Surfaced so the human can inspect what the
    # assistant is asking permission to run before approving.
    args: JSON!
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

type ChatMessageToolApprovalResponse {
    chatMessageId: ID!
    approvalId: String!
    approved: Boolean!
    # Optional free-text justification the human typed when responding. The
    # SDK's `ToolApprovalResponse` carries this through to the synthetic
    # denied tool-result so the LLM sees *why* a call was declined.
    reason: String
    createdAt: DateTime!
}

# --- Assistant input collection ----------------------------------------------
#
# A single assistant turn that asks the user for one or more structured values.
# Each entry in `inputs` is a typed slot — see `union ChatAssistantInput`.
# The user's response is a single `ChatMessageUserInput` carrying one
# `ChatMessageUserInputAnswer` per answered slot (all-or-nothing submit).

type ChatMessageAssistantInputCollection {
    chatMessageId: ID!
    prompt: String!
    inputs: [ChatAssistantInput!]!
    # `Form` renders every slot at once; `StepThrough` walks the user through
    # one slot at a time. The submitted answer set is identical between modes —
    # the wizard accumulates drafts client-side and submits the same batch the
    # form does. Picked by the LLM via the `promptUserForInput` tool's `mode`
    # input; defaults to `Form`.
    #
    # Plain `String!` (not a GraphQL enum) so the typescript-operations
    # codegen plugin doesn't re-emit a duplicate type alias next to the one
    # the typescript plugin already emits. Same workaround the inlined
    # mutations use for named input types — see chat.md.
    mode: String!
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

union ChatAssistantInput =
    | ChatAssistantInputDate
    | ChatAssistantInputDateRange
    | ChatAssistantInputDateTime
    | ChatAssistantInputTime
    | ChatAssistantInputSingleSelect
    | ChatAssistantInputMultiSelect
    | ChatAssistantInputBoolean
    | ChatAssistantInputText
    | ChatAssistantInputOtp

type ChatAssistantInputDate {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputDateRange {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputDateTime {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputTime {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputSingleSelect {
    inputId: ID!
    prompt: String!
    options: [String!]!
}

type ChatAssistantInputMultiSelect {
    inputId: ID!
    prompt: String!
    options: [String!]!
}

type ChatAssistantInputBoolean {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputText {
    inputId: ID!
    prompt: String!
}

# Six-digit one-time code. Wire-shape is identical to `ChatAssistantInputText`
# (the answer is a `ChatAssistantInputValueString`), but the slot kind is
# distinct so the UI can render the six-box `<InputOTP>` component instead of
# a free-text field. Used exclusively by the visitor chat after
# `submitProjectRequest` to verify ownership of the supplied email address —
# see `docs/features/project-requests.md`.
type ChatAssistantInputOtp {
    inputId: ID!
    prompt: String!
}

# --- User response to an assistant input collection --------------------------

type ChatMessageUserInput {
    chatMessageId: ID!
    # Null for anonymous visitor responses — same rationale as
    # `ChatMessageUser.author`.
    author: User
    collectionMessageId: ID!
    # Real submits carry one entry per answered slot; an empty list signals
    # the row is protocol-only — written by `chatMessageCreate` to close an
    # open collection when the user sent a free-text message instead of
    # filling the form. See "Pivoting away from an open collection" in
    # docs/architecture/chat.md.
    answers: [ChatMessageUserInputAnswer!]!
    createdAt: DateTime!
}

type ChatMessageUserInputAnswer {
    inputId: ID!
    value: ChatAssistantInputValue!
}

union ChatAssistantInputValue =
    | ChatAssistantInputValueDate
    | ChatAssistantInputValueDateRange
    | ChatAssistantInputValueDateTime
    | ChatAssistantInputValueTime
    | ChatAssistantInputValueString
    | ChatAssistantInputValueStringList
    | ChatAssistantInputValueBoolean

type ChatAssistantInputValueDate {
    date: Date!
}

type ChatAssistantInputValueDateRange {
    from: Date!
    to: Date!
}

type ChatAssistantInputValueDateTime {
    dateTime: DateTime!
}

type ChatAssistantInputValueTime {
    # ISO 8601 local time, e.g. "14:30"
    time: String!
}

type ChatAssistantInputValueString {
    value: String!
}

type ChatAssistantInputValueStringList {
    values: [String!]!
}

type ChatAssistantInputValueBoolean {
    boolean: Boolean!
}

# --- Top-level chat message union --------------------------------------------

union ChatMessage =
    | ChatMessageUser
    | ChatMessageUserInput
    | ChatMessageAssistantText
    | ChatMessageToolCall
    | ChatMessageToolApprovalRequest
    | ChatMessageToolApprovalResponse
    | ChatMessageAssistantInputCollection

type Chat {
    chatId: ID!
    title: String!
    lastModifiedAt: DateTime!
    # Flat insertion-ordered list. Day-grouping is a render-time concern in the
    # client (the live `chatUpdates` subscription delivers raw messages, so the
    # client has to be the grouping authority anyway).
    messages: [ChatMessage!]!
}

input UserCreate {
    name: String!
}

input UserUpdate {
    name: String!
}

type User {
    userId: ID!
    name: String!
    # Workspace read namespace — non-null only for the session's own admin user
    # (`Users.isAdmin = true`). Null for visitors, non-admin logged-in users, and
    # any future cross-user lookups. Lets surfaces like the public landing page
    # ask "is the current visitor an admin?" with a single nullable field check
    # instead of catching a `guardAdmin` exception. Mutations still live on
    # `Mutation.admin`. See `docs/architecture/workspace-access.md`.
    admin: Admin
}

type Session {
    sessionId: ID!
    user: User
    # Visitor-assistant chats owned by this session, most-recent first. Empty
    # for sessions that have never started a visitor chat. The `messages`
    # field on each entry is empty — fetch a single chat through
    # `Session.visitorChatFindOne(chatId)` to materialize its transcript. Used
    # by the chat dialog's empty state so a returning visitor can resume a
    # prior conversation.
    visitorChatFindMany: [Chat!]!
    # A single visitor chat owned by this session. Resolves only when the
    # chat row has `scope = 'public'` AND `sessionId = sessionFindOne.sessionId`
    # — a stolen chatId from another session is rejected even if the scope
    # is correct. Admin reads still use
    # `sessionFindOne.user.admin.adminChatFindOne(...)` /
    # `sessionFindOne.user.admin.adminPublicChatFindOne(...)` instead. See
    # `docs/architecture/multi-agent-chat.md`.
    visitorChatFindOne(chatId: ID!): Chat!
    # Rolling-24h cap on visitor-chat user messages from this requester.
    # Counted across (this session) OR (other sessions sharing this `ipHash`)
    # so clearing cookies does not reset the bucket. The visitor dialog
    # renders `used / limit` and the time until the oldest in-window message
    # ages out. See `docs/features/chat-visitor.md`.
    visitorChatQuotaFindOne: VisitorChatQuota!
}

# Read-only quota snapshot. `resetsAt` is the moment the oldest in-window
# message ages out of the rolling 24h window — null when `used = 0`. Counts
# only user messages on `scope = 'public'` chats; admin chats are not
# counted. See `docs/features/chat-visitor.md`.
type VisitorChatQuota {
    used: Int!
    limit: Int!
    resetsAt: DateTime
}

type MutationResult {
    success: Boolean!
    referenceId: ID
    # Ids of rows touched by a batch mutation, in input order. Empty for
    # non-batch mutations and for callers that do not need the ids back.
    referenceIds: [ID!]
}

type ChatMessageCreateResult {
    chatId: ID!
    chatMessageId: ID!
}

type UserMutation {
    userUpdate(user: UserUpdate!): MutationResult!
    userSessionTerminateMany(sessionIds: [ID!]!): MutationResult!
}

# --- User-input answer write shape -------------------------------------------
#
# GraphQL has no input unions, so we follow the same flat-discriminator pattern
# the `promptUserForInput` Zod tool schema uses: a `kind` enum drives which of
# the optional fields is read. The resolver validates the populated field
# matches `kind` and rejects mismatches before persistence.

enum ChatAssistantInputValueKind {
    Date
    DateRange
    DateTime
    Time
    String
    StringList
    Boolean
}

input ChatMessageUserInputAnswerCreate {
    inputId: ID!
    kind: ChatAssistantInputValueKind!
    date: Date
    dateRangeFrom: Date
    dateRangeTo: Date
    dateTime: DateTime
    time: String
    string: String
    stringList: [String!]
    boolean: Boolean
}

input ChatAssistantOptions {
    generationId: ID
    requireToolCallApprovals: Boolean!
    # Admin namespace only — visitor mutations ignore this. Picks one of the
    # ids in `Admin.chatConfig.availableModels`; the agent falls back to the
    # admin's saved default when omitted. The runtime rejects unknown ids
    # (fail fast) so an invalid pick never reaches the provider. See
    # `docs/features/admin-chat-config.md`.
    modelId: String
}

type Query {
    sessionFindOne: Session!
    # Public CV namespace — surfaces the timeline (`/cv`) and the
    # skill/hobby blocks (`/about`). Always returns lists ordered by their
    # `position` column, ascending. Edits land via the admin namespace
    # (`Mutation.admin.cv*`), gated by `guardAdminMutation`. See
    # `docs/features/cv.md`.
    publicCvFindOne: CvQuery!
}

# Workspace read namespace — Cem's own chats and a separate window onto the
# visitor chats his site recorded. The split exists because the two have
# different agents, different system prompts, and different on-row tools; the
# `Chat` type itself is the same.
type Admin {
    # Visitor (`scope = 'public'`) chats, newest first.
    adminPublicChatFindMany: [Chat!]!
    # A single visitor chat by id. Rejects `scope = 'admin'` chats.
    adminPublicChatFindOne(chatId: ID!): Chat!
    # Admin (`scope = 'admin'`) chats, newest first by `lastModifiedAt`.
    # Backs the workspace assistant sidebar's chat browser. All three
    # arguments are optional so the field is drop-in compatible with an
    # unfiltered "give me every admin chat" call:
    #
    #   - `limit` caps the returned batch (server clamps to a sane
    #     ceiling); omit for the full list.
    #   - `offset` picks the page (0-indexed); omit for the top of the
    #     list.
    #   - `query` — when set to a non-blank trimmed string — filters the
    #     underlying rows by matching either the chat title OR any
    #     user-message body (case-insensitive substring). Assistant text
    #     is intentionally not searched.
    #
    # The returned `Chat` shells carry an empty `messages` array — fetch
    # the transcript with `adminChatFindOne(chatId)` when the user opens
    # one. Pair with `adminChatCount(query)` to drive "AdminMediaShow more" (server
    # does not return a page-size + hasMore combo).
    adminChatFindMany(limit: Int, offset: Int, query: String): [Chat!]!
    # Total number of admin chats matching the same optional `query` as
    # `adminChatFindMany(...)`. The client subtracts `offset + items.length`
    # to decide whether "AdminMediaShow more" is still meaningful.
    adminChatCount(query: String): Int!
    # A single admin chat by id. Rejects `scope = 'public'` chats.
    adminChatFindOne(chatId: ID!): Chat!
    # The AI-built compass of Cem. Reads three synthesized text artifacts
    # (`summary`, `prose`, `psychology`) plus the underlying observations
    # the analyzer extracted from admin chats. The `summary` field is the
    # only piece fed back into the personal-assistant system prompt; the
    # rest is read-only insight surfaced at `/workspace/compass`. See
    # `docs/features/compass.md`.
    adminCompassFindOne: AdminCompass!
}

# Compass artifacts surfaced at `/workspace/compass`. Three text fields
# produced by the synthesizer plus a list-and-count view onto the underlying
# observations.
#
# Firewall: the resolver behind `summary` is the SAME row the analyzer reads
# into the assistant prompt — by design. `prose` and `psychology` are
# surfaced ONLY through this namespace and are never injected anywhere.
type AdminCompass {
    # Short factual summary (≤ ~500 tokens), used as system-prompt context for
    # admin chats. Empty until the first synthesis.
    summary: String!
    # Long-form, human-readable portrait. Read by Cem on /workspace/compass.
    prose: String!
    # Psychological synthesis. NEVER fed back to any agent.
    psychology: String!
    # Null until the synthesizer has run at least once.
    synthesizedAt: DateTime
    # Model id that produced the latest synthesis. Surfaced as a faint
    # subtitle next to the timestamp so Cem knows which LLM generated the
    # text he is reading.
    synthesisModelId: String
    # Non-dismissed observations recorded since the last synthesis. Drives
    # the "Synthesize now" CTA's badge ("12 new observations").
    observationsSinceSynthesis: Int!
    # True while a `compass-synthesize` job is queued (created/active/retry).
    # Derived live from pg-boss — never persisted on the `Compass` row, so
    # a crashed worker can never leave this stuck on (pg-boss expires
    # `active` rows after the job's `expireInSeconds`).
    synthesisInProgress: Boolean!
    # Observations, newest first. `category` filters server-side; `dismissed`
    # toggles between active rows (default, null = active only),
    # `dismissed: true` shows dismissed rows, `dismissed` omitted with
    # `includeDismissed: true` shows both.
    adminCompassObservationFindMany(category: CompassObservationCategory, includeDismissed: Boolean): [CompassObservation!]!
    # All psychological-interview rows newest-first — pending + in-progress at
    # the top, then completed/skipped history beneath. See
    # `docs/features/compass.md` ("Psychological-interview agent").
    adminCompassInterviewFindMany: [CompassInterview!]!
    # A single interview by id, including its message transcript. Returns
    # null when the id doesn't resolve.
    adminCompassInterviewFindOne(interviewId: ID!): CompassInterview
    # The open interview if one exists — `pending` (Cem hasn't started yet)
    # or `in_progress` (mid-conversation). The page surfaces this as the
    # "interview waiting" / "resume" card. Null when no open interview.
    adminCompassInterviewPendingFindOne: CompassInterview
    # AI-suggested next interview topic — set by the analyzer when a message
    # contains a time-sensitive signal. Null when no suggestion is active.
    scheduledInterviewTopic: CompassInterviewTopic
    # When the suggested interview should happen (set alongside topic).
    scheduledInterviewAt: DateTime
    # One-sentence reason the analyzer emitted this suggestion.
    scheduledInterviewReason: String
}

enum CompassObservationCategory {
    factual
    behavioral
    psychological
}

# One row produced by the analyzer per admin user-message that revealed
# something new. `sourceChatMessage` is the user message it came from — null
# only if that message has since been deleted.
type CompassObservation {
    observationId: ID!
    category: CompassObservationCategory!
    content: String!
    # 0..100 (percent) confidence the analyzer reported. Null when the
    # analyzer omitted the field. The UI renders this as a faint dot row.
    confidence: Int
    analyzerModelId: String
    # Source message this observation was derived from. Null only when the
    # message has been deleted since (the observation outlives the message —
    # the synthesizer has already absorbed it).
    sourceChatMessageId: ID
    sourceChatId: ID
    # Source interview message — set when the analyzer extracted this row
    # from a psychological-interview reply rather than an admin chat. Exactly
    # one of `sourceChatMessageId` / `sourceInterviewMessageId` is set per row.
    # Null when the originating message has been deleted (cascades to null
    # like the chat-side FK).
    sourceInterviewMessageId: ID
    # Interview the source message belongs to, surfaced for deep-linking
    # from the observations stream back into the originating interview's
    # transcript. Null when `sourceInterviewMessageId` is null.
    sourceInterviewId: ID
    # `null` while active, set on dismiss. Dismissed observations are
    # excluded from synthesis input but kept as an audit trail.
    dismissedAt: DateTime
    createdAt: DateTime!
}

# --- Compass psychological interviews ---------------------------------------
#
# A recurring job creates a `pending` row on a cadence; Cem starts it from
# `/workspace/compass`; the interviewer agent and his replies fill
# `CompassInterviewMessages` until the agent calls `concludeInterview` or
# Cem ends early. See `docs/features/compass.md`.
type CompassInterview {
    interviewId: ID!
    status: CompassInterviewStatus!
    dueAt: DateTime!
    startedAt: DateTime
    completedAt: DateTime
    endReason: CompassInterviewEndReason
    triggerReason: CompassInterviewTriggerReason!
    topic: CompassInterviewTopic!
    # Denormalized count of observations the analyzer extracted from this
    # interview's user replies. Surfaced on the past-interviews list so Cem
    # sees at a glance how much signal a given week produced.
    observationCount: Int!
    # Full transcript in chronological order. Cem's replies and the
    # interviewer's questions interleave. Always present (empty array
    # before the first turn lands).
    messages: [CompassInterviewMessage!]!
}

type CompassInterviewMessage {
    interviewMessageId: ID!
    role: CompassInterviewMessageRole!
    content: String!
    # Model id used to produce assistant turns. Null on user turns.
    modelId: String
    createdAt: DateTime!
}

enum CompassInterviewStatus {
    pending
    in_progress
    completed
    skipped
}

enum CompassInterviewEndReason {
    agent_satisfied
    user_ended
    skipped
}

enum CompassInterviewTriggerReason {
    scheduled
    manual
}

enum CompassInterviewTopic {
    general
    career
    relationships
    fitness
    health
    stress
}

enum CompassInterviewMessageRole {
    user
    assistant
}

type Mutation {
    userCreate(user: UserCreate!): MutationResult!
    user: UserMutation!
    # --- Visitor chat ---------------------------------------------------------
    # The three mutations below operate on `scope = 'public'` chats and
    # dispatch to the visitor agent (`agentVisitor`). The agent
    # factory is selected by the access path — the resolver wires it in;
    # callers do NOT pass it. Mismatched scope (e.g. an admin chatId reaching
    # this namespace) is rejected by the command.
    # `currentPagePath` is the route the visitor's client was on when the
    # message was sent (e.g. `/projects`, `/en/cv`). Forwarded into the
    # agent's system prompt for this turn only — not persisted. Optional;
    # server-side callers (tests) may omit it. See
    # `docs/features/chat-visitor.md`.
    chatMessageCreate(
        chatId: ID
        message: String!
        fileUploadIds: [ID!]
        assistantOptions: ChatAssistantOptions!
        currentPagePath: String
    ): ChatMessageCreateResult
    chatInputCollectionRespond(
        collectionMessageId: ID!
        answers: [ChatMessageUserInputAnswerCreate!]!
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
    chatToolApprovalRespond(
        approvalId: String!
        approved: Boolean!
        reason: String
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
    # Workspace-only mutations, gated by `guardAdminMutation`.
    admin: AdminMutation!
}

# Workspace write namespace — same chat shape as the visitor mutations above,
# routed to `agentPersonalAssistant` and operating on `scope = 'admin'` chats.
type AdminMutation {
    chatMessageCreate(
        chatId: ID
        message: String!
        fileUploadIds: [ID!]
        assistantOptions: ChatAssistantOptions!
        currentPagePath: String
    ): ChatMessageCreateResult
    chatInputCollectionRespond(
        collectionMessageId: ID!
        answers: [ChatMessageUserInputAnswerCreate!]!
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
    chatToolApprovalRespond(
        approvalId: String!
        approved: Boolean!
        reason: String
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
}

# --- Chat live updates -------------------------------------------------------
#
# A single subscription that delivers every event of an in-flight assistant
# turn — newly persisted `ChatMessage` rows (user message, tool call, approval
# request/response, input collection, final assistant text) and assistant-text
# deltas during streaming. Keyed by an ephemeral, client-allocated
# `generationId` (UUIDv4); the unguessable id IS the capability today. Real
# chat-level authorization will layer on once chats grow user ownership.
#
# `ChatUpdateAssistantTextChunk.chatMessageId` is pre-allocated server-side
# before streaming begins; it equals the id of the eventual
# `ChatMessageAssistantText` row that arrives as `ChatUpdateMessageAppended`
# at end-of-stream. Clients use it to swap their in-place streaming row for
# the persisted message with no layout shift.

type ChatUpdateMessageAppended {
    message: ChatMessage!
}

type ChatUpdateAssistantTextChunk {
    chatMessageId: ID!
    delta: String!
}

# Marker variant published exactly once per turn — when `chatAssistantTurnRun`
# exits (success or failure). Lets the client tear down per-turn state
# (composer lock, active streamingId) without waiting on the mutation that
# kicked the turn off, since the mutation now returns as soon as the user-side
# row is committed and the agent runs detached.
type ChatUpdateTurnEnded {
    generationId: ID!
}

union ChatUpdate = ChatUpdateMessageAppended | ChatUpdateAssistantTextChunk | ChatUpdateTurnEnded

# --- Compass interview live updates -----------------------------------------
#
# Parallel to `chatUpdates`, but keyed on interview-message ids instead of chat
# ones because the interviewer writes to its own `CompassInterviewMessages`
# table (see `docs/features/workspace-compass.md`). Same three-variant shape:
# a newly-persisted row, a streaming delta on the pre-allocated assistant row
# id, and a terminal `turnEnded` (with `concluded: true` when the agent called
# `concludeInterview`, so the client can flip the row's status without waiting
# for the next `userUpdates` push).

type CompassInterviewUpdateMessageAppended {
    message: CompassInterviewMessage!
}

type CompassInterviewUpdateAssistantTextChunk {
    interviewMessageId: ID!
    delta: String!
}

type CompassInterviewUpdateTurnEnded {
    generationId: ID!
    concluded: Boolean!
}

union CompassInterviewUpdate =
    | CompassInterviewUpdateMessageAppended
    | CompassInterviewUpdateAssistantTextChunk
    | CompassInterviewUpdateTurnEnded

type Subscription {
    userUpdates: User!
    chatUpdates(generationId: ID!): ChatUpdate!
    compassInterviewUpdates(generationId: ID!): CompassInterviewUpdate!
}

# --- CV ----------------------------------------------------------------------
#
# Editable CV content surfaced on `/cv` and `/about`. Bilingual text rides
# as paired `*De` / `*En` fields — the client renders the locale-matching
# pair. Proper nouns (company names, institution names) stay on a single
# untranslated field. `CvEducation`, `CvSkill`, and `CvHobby` carry a
# `position` field that the editor rewrites via the matching `*Reorder`
# mutation; `CvExperience` has none — it is intrinsically date-ordered, so
# the read query sorts by `endDate` (ongoing first) and `startDate`. See
# `docs/features/cv.md`.

type CvExperience {
    cvExperienceId: ID!
    roleDe: String!
    roleEn: String!
    company: String!
    # ISO 8601 calendar date (yyyy-mm-dd).
    startDate: Date!
    # Null marks an ongoing role. The renderer formats it as "heute" / "today".
    endDate: Date
    descriptionDe: String!
    descriptionEn: String!
    technologies: [String!]!
    managerName: String
}

type CvEducation {
    cvEducationId: ID!
    degreeDe: String!
    degreeEn: String!
    institution: String!
    # Optional course of study within the degree (e.g. "Informatik").
    subjectDe: String!
    subjectEn: String!
    # Education entries occasionally have only an end date (e.g. Abitur).
    startDate: Date
    endDate: Date!
    # Free-form notes per locale: "Kursprecher", "Abschlussprüfung Informatik: 1+", etc.
    notesDe: String!
    notesEn: String!
    position: Int!
}

# `category` is a flat enum — see the CvSkillCategory definition. Skill
# labels themselves are not translated.
type CvSkill {
    cvSkillId: ID!
    category: CvSkillCategory!
    label: String!
    position: Int!
}

enum CvSkillCategory {
    capabilities
    frameworks
    services
    tools
    languages
}

type CvHobby {
    cvHobbyId: ID!
    textDe: String!
    textEn: String!
    # Optional anchor year for entries like "Seit 2011 Karate".
    since: Int
    position: Int!
}

type CvQuery {
    publicCvExperienceFindMany: [CvExperience!]!
    publicCvEducationFindMany: [CvEducation!]!
    publicCvSkillFindMany: [CvSkill!]!
    publicCvHobbyFindMany: [CvHobby!]!
}

# --- CV admin write inputs ---------------------------------------------------
#
# Upserts use a nullable id: when present the row with that id is updated,
# when absent a new row is created. For the three position-ordered entities
# (education, skills, hobbies) the `position` slot lets the editor place a
# new row at a specific spot; reordering as a whole is a separate
# `*Reorder` mutation that takes the full id array. `CvExperience` has no
# `position` — the read query sorts it by `endDate` / `startDate`.

input CvExperienceInput {
    cvExperienceId: ID
    roleDe: String!
    roleEn: String!
    company: String!
    startDate: Date!
    endDate: Date
    descriptionDe: String!
    descriptionEn: String!
    technologies: [String!]!
    managerName: String
}

input CvEducationInput {
    cvEducationId: ID
    degreeDe: String!
    degreeEn: String!
    institution: String!
    subjectDe: String!
    subjectEn: String!
    startDate: Date
    endDate: Date!
    notesDe: String!
    notesEn: String!
    position: Int!
}

input CvSkillInput {
    cvSkillId: ID
    category: CvSkillCategory!
    label: String!
    position: Int!
}

input CvHobbyInput {
    cvHobbyId: ID
    textDe: String!
    textEn: String!
    since: Int
    position: Int!
}

# --- Projects, Tasks, AdminProject requests ---------------------------------------
#
# Workspace projects surface: incoming visitor `AdminProjectRequest`s plus
# admin-only `AdminProject` and `AdminProjectTask` rows. Single-language (no `*De` / `*En`
# pairs — never surfaced publicly). See `docs/features/projects-workspace.md`.

enum AdminProjectRequestStatus {
    pendingOtp
    emailVerified
    archived
}

enum AdminProjectRequestType {
    webApp
    mobile
    consulting
    aiIntegration
    other
}

# A visitor-submitted project brief. Surfaced on the workspace projects
# Inbox tab once `status = emailVerified`. The `otpHash` / `otpSalt`
# columns are deliberately not exposed — the GraphQL surface is read-only
# triage, not OTP introspection.
type AdminProjectRequest {
    projectRequestId: ID!
    chatId: ID
    name: String!
    email: String!
    company: String
    projectType: AdminProjectRequestType!
    description: String!
    budget: String
    timeline: String
    status: AdminProjectRequestStatus!
    verifiedAt: DateTime
    createdAt: DateTime!
    updatedAt: DateTime!
    # AdminProject this request was converted into, if any. Lets the Inbox row
    # render a "Converted →" backlink. Set when `adminProjectsUpsert` creates a
    # project with `sourceRequestId` pointing at this row; null otherwise.
    convertedProject: AdminProject
}

enum AdminProjectStatus {
    idea
    planning
    active
    paused
    done
    archived
}

type AdminProject {
    projectId: ID!
    title: String!
    description: String
    notes: String
    status: AdminProjectStatus!
    position: Int!
    # Source visitor request this project was created from, when applicable.
    # Null for hand-created projects.
    sourceRequest: AdminProjectRequest
    startedAt: DateTime
    completedAt: DateTime
    createdAt: DateTime!
    updatedAt: DateTime!
    # AdminProject-bound tasks, ordered by `position` within their status bucket.
    tasks: [AdminProjectTask!]!
    # Timeline of events and work sessions, newest first.
    activities: [AdminProjectActivity!]!
    # Sum of `durationSec` across `kind = work` activities, in seconds.
    # Zero when no timer has ever run against the project.
    totalWorkSec: Int!
    # All link resources hanging off the project, newest first. The detail
    # page's "Links" tab renders this full list; the project header surfaces
    # the subset where `pinned = true`.
    links: [AdminProjectLink!]!
    # All file resources hanging off the project, newest first. Same
    # rendering split as `links` — Files tab shows everything; the header
    # surfaces pinned only.
    files: [AdminProjectFile!]!
}

enum AdminProjectTaskStatus {
    backlog
    todo
    doing
    blocked
    done
}

# Perceived weight of a task — quick / focused / deep. Drives the left-edge
# color strip on the todo row card. Nullable; unclassified rows render
# without a strip.
enum AdminProjectTaskEffort {
    quick
    focused
    deep
}

# When the user intends to act on the task, independent of any due date.
# A due date says "must be done by"; the bucket says "I want to do this".
# Nullable; a null row floats in the general list.
enum AdminProjectTaskWhenBucket {
    today
    week
    someday
    waiting
}

type AdminProjectTask {
    taskId: ID!
    # Owning project. Null = standalone todo (surfaced on the Todos tab).
    projectId: ID
    title: String!
    notes: String
    status: AdminProjectTaskStatus!
    position: Int!
    dueAt: DateTime
    completedAt: DateTime
    # Perceived weight — quick / focused / deep. Optional.
    effort: AdminProjectTaskEffort
    # When the user intends to act. Independent of `dueAt`. Optional.
    whenBucket: AdminProjectTaskWhenBucket
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Categorizes an entry on the project timeline. `clientContact` and
# `meeting` carry a `channel`; the others omit it.
enum AdminProjectActivityKind {
    clientContact
    meeting
    work
    offer
    milestone
    note
}

# How the contact / meeting happened. Only meaningful on
# `clientContact` / `meeting` rows.
enum AdminProjectActivityChannel {
    malt
    email
    phone
    videoCall
    inPerson
    aiAssistant
    other
}

# Sidedness of an activity row. Drives the chat-style timeline layout on the
# project detail page — `outgoing` rows render right-aligned (from Cem),
# `incoming` rows left-aligned (from the client), `internal` rows render as
# centered system markers (work sessions, freeform notes, milestones).
enum AdminProjectActivityDirection {
    outgoing
    incoming
    internal
}

# A single entry on a project's timeline. Covers both logged events
# (call, email, offer sent) and timed work sessions — the latter populate
# `startedAt` / `endedAt` and have `kind = work`.
type AdminProjectActivity {
    activityId: ID!
    projectId: ID!
    # Optional task this activity is attached to. Lets totals roll up per
    # task without forcing every activity to pick one.
    taskId: ID
    kind: AdminProjectActivityKind!
    channel: AdminProjectActivityChannel
    # Sidedness of the row — drives the chat-style timeline layout. Always
    # set; defaults to `internal` for `work` / `note` / `milestone` kinds.
    direction: AdminProjectActivityDirection!
    # Optional one-line heading. Timer rows and agent-authored entries set
    # it; the manual composer leaves it null and puts the single free-form
    # summary in `notes`.
    title: String
    notes: String
    # When the event happened. Equals `startedAt` on timer rows.
    occurredAt: DateTime!
    # Set on work-timer rows; null on event rows.
    startedAt: DateTime
    # Null while a timer is running.
    endedAt: DateTime
    # Cached `endedAt - startedAt` in seconds. Settable directly on event
    # rows ("the call was 45 min") without running a timer.
    durationSec: Int
    # Offer-row fields. Meaningful only when `kind = offer`. `amountCents`
    # is integer cents in EUR; the editor formats and parses.
    amountCents: Int
    offerStatus: AdminProjectOfferStatus
    createdAt: DateTime!
    updatedAt: DateTime!
    # Links and files born from this activity (i.e. attached at the moment
    # the activity was logged). Pinned status lives on the resource row,
    # not the activity — the same link / file shows up under the project's
    # `links` / `files` lists too.
    links: [AdminProjectLink!]!
    files: [AdminProjectFile!]!
}

# Lifecycle of an offer row. Only meaningful when the parent activity has
# `kind = offer`. A withdrawn offer keeps the row for history.
enum AdminProjectOfferStatus {
    sent
    accepted
    rejected
    withdrawn
}

# Categorizes an external URL attached to a project. Drives the icon /
# label fallback on the link card.
enum AdminProjectLinkKind {
    github
    malt
    figma
    gdrive
    notion
    invoice
    offer
    other
}

# An external URL associated with a project. Optionally born from an
# activity entry (`activityId` non-null) and optionally pinned to the
# project header's rail (`pinned = true`). The Links tab on the detail
# route renders the full list regardless of `pinned`.
type AdminProjectLink {
    projectLinkId: ID!
    projectId: ID!
    # Activity this link was logged against, when applicable. Null for
    # links added directly at project level.
    activityId: ID
    url: String!
    # Free-form label. Falls back to the URL host when empty.
    label: String
    kind: AdminProjectLinkKind!
    # True surfaces this link in the project header's pinned rail.
    pinned: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Categorizes a file attached to a project. Drives the badge on the
# file card and the default folder grouping on the Files tab.
enum AdminProjectFileKind {
    offer
    invoice
    contract
    screenshot
    other
}

# An uploaded file attached to a project. Wraps a row from the shared
# `FileUpload` store with project-level metadata (kind, pin state, source
# activity). The `fileUpload.url` field is the download path the UI links
# to; the underlying bytes are served by `/api/file-uploads/:id`.
type AdminProjectFile {
    projectFileId: ID!
    projectId: ID!
    activityId: ID
    fileUpload: FileUpload!
    label: String
    kind: AdminProjectFileKind!
    pinned: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# A standalone markdown document the assistant drafted from chat and the admin
# edits in the workspace document panel. `content` is the decoded UTF-8 body of
# the underlying upload; `fileUpload.url` still serves the raw bytes for
# download. See `docs/features/workspace-files.md`.
type WorkspaceFile {
    workspaceFileId: ID!
    filename: String!
    label: String
    content: String!
    createdAt: DateTime!
    updatedAt: DateTime!
    fileUpload: FileUpload!
}

# Workspace projects read namespace — mounted under `Admin.adminProjectFindMany` so
# the resolver chain on `User.admin` covers it.
extend type Admin {
    # Incoming visitor project briefs, newest first. The `status` argument
    # filters server-side; omit to return every state (including the
    # half-baked `pendingOtp` rows, mostly useful for debugging).
    adminProjectRequestFindMany(status: AdminProjectRequestStatus): [AdminProjectRequest!]!
    # Lightweight count of verified-and-untriaged requests. Drives the
    # inbox badge on the workspace hub. Equivalent to
    # `adminProjectRequestFindMany(status: emailVerified)` minus rows already
    # converted into a project — but a single `count(*)` round-trip
    # instead of materialising every row + its join.
    adminProjectRequestInboxCount: Int!
    # All projects, ordered by status then `position`. The board groups
    # client-side by status. `status` argument narrows server-side when set.
    adminProjectFindMany(status: AdminProjectStatus): [AdminProject!]!
    # Single project by id, loaded fully (tasks, activities, links, files,
    # source request). Powers the `/workspace/projects/$projectId` detail
    # route. Raises `notFound` when the id does not exist.
    adminProjectFindOne(projectId: ID!): AdminProject!
    # Standalone todos: rows with `projectId IS NULL`. AdminProject-bound tasks
    # are reached through `AdminProject.tasks` so `/workspace/todos` and the
    # project board don't fight over the same list.
    adminStandaloneTaskFindMany: [AdminProjectTask!]!
    # Count of standalone todos in an open state (`todo` or `doing`).
    # Drives the Todos badge on the workspace hub. `done` rows are
    # excluded so the badge tracks "still to do" and not lifetime volume.
    adminStandaloneTaskOpenCount: Int!
    # The single currently-running work timer, or null if none. Drives the
    # header badge and per-project timer pill. At most one row exists with
    # `endedAt IS NULL AND kind = 'work'` — the DB enforces this via a
    # partial unique index.
    adminProjectActiveTimerFindOne: AdminProjectActivity
    # CV editor read namespace — mounts the same `CvQuery` shape the public
    # `/cv` and `/about` surfaces consume, but reached through `User.admin`
    # so the workspace CV page can seed-and-subscribe under `userUpdates`
    # like every other admin surface. The mutations stay on
    # `AdminMutation.cv*` and continue to publish `userUpdates` after commit.
    # See `docs/architecture/state-synchronization.md`.
    adminCvFindOne: CvQuery!
    # Single standalone workspace file (assistant-authored markdown) by id,
    # with its decoded `content`. Powers the document editor panel. Raises
    # `notFound` when the id does not exist or is not owned by the admin.
    adminWorkspaceFileFindOne(workspaceFileId: ID!): WorkspaceFile!
}

input AdminProjectCreate {
    projectId: ID
    title: String!
    description: String
    notes: String
    status: AdminProjectStatus!
    # Optional on create — when omitted, the server appends the new row to
    # the end of the `planning` column (max(position) + 1). Required on
    # update; the editor always knows the board state and passes it back.
    position: Int
    # When set on a create, the new project is the conversion of an
    # `emailVerified` `AdminProjectRequest`. `adminProjectsUpsert` validates the
    # request is in that state and archives it in the same transaction
    # as the project insert. Ignored on update.
    sourceRequestId: ID
    startedAt: DateTime
    completedAt: DateTime
}

input AdminProjectTaskCreate {
    taskId: ID
    projectId: ID
    title: String!
    notes: String
    status: AdminProjectTaskStatus!
    position: Int!
    dueAt: DateTime
    completedAt: DateTime
    effort: AdminProjectTaskEffort
    whenBucket: AdminProjectTaskWhenBucket
}

# Activity create / update payload. `activityId` toggles upsert mode.
# Server validates that `channel` is set only when `kind` is
# `clientContact` or `meeting`. For event rows leave `startedAt` /
# `endedAt` null; the timer mutations write those columns directly.
#
# `attachLink*` and `attachFile*` are optional one-shot extensions: when
# present on a create, the server inserts a matching `AdminProjectLink` /
# `AdminProjectFile` in the same transaction with `activityId` pointing at the
# new activity. Lets the editor say "log offer + attach PDF" without two
# round-trips. Ignored on update — edit the resource rows directly through
# their own mutations.
input AdminProjectActivityCreate {
    activityId: ID
    projectId: ID!
    taskId: ID
    kind: AdminProjectActivityKind!
    channel: AdminProjectActivityChannel
    # Sidedness override. The command normalizes this — `work` / `note` /
    # `milestone` are always stored as `internal` regardless of what the
    # client sends. For `clientContact` / `meeting` / `offer` the field is
    # respected; when omitted the command picks a kind-appropriate default
    # (`clientContact` → `incoming`, `meeting` / `offer` → `outgoing`).
    direction: AdminProjectActivityDirection
    title: String
    notes: String
    occurredAt: DateTime!
    durationSec: Int
    amountCents: Int
    offerStatus: AdminProjectOfferStatus
    attachLinkUrl: String
    attachLinkKind: AdminProjectLinkKind
    attachLinkLabel: String
    attachLinkPinned: Boolean
    attachFileUploadId: ID
    attachFileKind: AdminProjectFileKind
    attachFileLabel: String
    attachFilePinned: Boolean
}

# AdminProject-link create / update payload. `projectLinkId` toggles upsert
# mode. `activityId` may only be set on a create — once a link is born
# from an activity, the link survives the activity's deletion (the FK
# cascade-set-nulls).
input AdminProjectLinkUpsert {
    projectLinkId: ID
    projectId: ID!
    activityId: ID
    url: String!
    label: String
    kind: AdminProjectLinkKind!
    pinned: Boolean
}

# AdminProject-file create / update payload. Same shape as `AdminProjectLinkUpsert`
# but referencing an already-uploaded `FileUpload` by id. The client first
# uploads the file via `POST /api/file-uploads`, then calls this mutation
# with the returned `fileUploadId`.
input AdminProjectFileUpsert {
    projectFileId: ID
    projectId: ID!
    activityId: ID
    fileUploadId: ID!
    label: String
    kind: AdminProjectFileKind!
    pinned: Boolean
}

# One work-timer start. `adminProjectTimersStart` processes a batch of these
# sequentially inside one transaction — each element stops any open timer
# then inserts its own running row, so a multi-element batch ends with only
# the last row open. In practice the UI passes a one-element array.
input AdminProjectTimerStartInput {
    projectId: ID!
    taskId: ID
    title: String
}

# CV admin namespace — mounted under `AdminMutation.cv` so the existing
# `guardAdminMutation` gate covers it without a parallel Mutation entry.
extend type AdminMutation {
    cvExperiencesUpsert(cvExperiences: [CvExperienceInput!]!): MutationResult!
    cvExperiencesDelete(cvExperienceIds: [ID!]!): MutationResult!

    cvEducationsUpsert(cvEducations: [CvEducationInput!]!): MutationResult!
    cvEducationsDelete(cvEducationIds: [ID!]!): MutationResult!
    cvEducationReorder(orderedIds: [ID!]!): MutationResult!

    cvSkillsUpsert(cvSkills: [CvSkillInput!]!): MutationResult!
    cvSkillsDelete(cvSkillIds: [ID!]!): MutationResult!
    cvSkillReorder(orderedIds: [ID!]!): MutationResult!

    cvHobbiesUpsert(cvHobbies: [CvHobbyInput!]!): MutationResult!
    cvHobbiesDelete(cvHobbyIds: [ID!]!): MutationResult!
    cvHobbyReorder(orderedIds: [ID!]!): MutationResult!

    # Soft-dismiss an observation. The row stays in the DB but is excluded
    # from the synthesizer's input. A future "undismiss" mutation could clear
    # `dismissedAt`; today the page treats dismiss as final but reversible by
    # a re-run of the synthesizer over the older data.
    compassObservationDismiss(observationId: ID!): MutationResult!
    # Force a synthesis pass now. Enqueues the `compassSynthesize` job. The
    # job updates the `Compass` row and resets `observationsSinceSynthesis`.
    compassSynthesizeRequest: MutationResult!
    # Start a `pending` psychological interview — transitions it to
    # `in_progress` and runs the agent's opening turn. Idempotent: a repeat
    # call on an already-started interview is a no-op rather than a second
    # opener. See `docs/features/compass.md`.
    compassInterviewStart(interviewId: ID!, generationId: ID): MutationResult!
    # Append Cem's reply to an in-progress interview, run the next agent
    # turn, and persist the assistant's reply. Enqueues `compassAnalyze`
    # fire-and-forget for the user message. When the agent calls
    # `concludeInterview`, the interview row transitions to `completed`
    # automatically in the same call.
    compassInterviewMessageSend(interviewId: ID!, content: String!, generationId: ID): MutationResult!
    # User-initiated early end — moves an `in_progress` interview to
    # `completed` with `endReason='user_ended'`. Already-analyzed user
    # turns keep their observations; no new agent turn fires.
    compassInterviewEnd(interviewId: ID!): MutationResult!
    # Skip a `pending` interview without starting it. Clears the cron's
    # idempotency check so next week's invocation creates a fresh one.
    compassInterviewSkip(interviewId: ID!): MutationResult!
    # Manually create a `pending` interview off the cron cadence — the
    # "Start a new interview now" button on `/workspace/compass`. Idempotent
    # with the same "at most one open interview" guard as the scheduled
    # cron: if an open interview already exists, the mutation returns
    # success with that interview's id (the caller navigates to it) rather
    # than a second pending row. Optional `topic` selects the interview focus
    # (defaults to `general`). See `docs/features/compass.md`.
    compassInterviewStartNow(topic: CompassInterviewTopic): MutationResult!
    # Dismiss the AI-suggested interview hint on the Compass row without
    # acting on it. Clears `scheduledInterviewTopic/At/Reason` so the
    # suggestion card disappears.
    compassScheduledInterviewDismiss: MutationResult!

    # --- Workspace projects -------------------------------------------------
    # Archive an incoming request without converting it to a project. Flips
    # `status = archived` so the Inbox tab can hide it by default.
    adminProjectRequestArchive(projectRequestId: ID!): MutationResult!
    # Permanent delete. Use for spam that survived OTP verification.
    adminProjectRequestDelete(projectRequestId: ID!): MutationResult!
    # Batch create-or-update of projects. Every row with a `projectId` is
    # updated; every row without one is inserted. Conversion of a verified
    # `AdminProjectRequest` is the same call with `sourceRequestId` set on a
    # create — the server validates the request is `emailVerified`, links
    # the new project to it, and archives the request in the same
    # transaction. `referenceIds` echoes the row id per input in input order.
    adminProjectsUpsert(projects: [AdminProjectCreate!]!): MutationResult!
    adminProjectsDelete(projectIds: [ID!]!): MutationResult!
    adminProjectReorder(orderedIds: [ID!]!): MutationResult!

    adminProjectTasksUpsert(tasks: [AdminProjectTaskCreate!]!): MutationResult!
    adminProjectTasksDelete(taskIds: [ID!]!): MutationResult!
    # Rewrite `position` on the given task ids in array order. Caller scopes
    # the list to a single `(projectId, status)` bucket — the server does
    # not enforce membership in one bucket, but mixing buckets in one call
    # is meaningless.
    adminProjectTaskReorder(orderedIds: [ID!]!): MutationResult!
    # --- AdminProject activities & timer ----------------------------------------
    # Batch create-or-update of activity rows (call logged, email sent,
    # offer drafted, freeform note). `kind = work` rows are reserved for the
    # timer mutations and rejected here. `referenceIds` echoes the row id
    # per input in input order.

    adminProjectActivitiesUpsert(projectActivities: [AdminProjectActivityCreate!]!): MutationResult!
    adminProjectActivitiesDelete(activityIds: [ID!]!): MutationResult!

    # Start work timers. Each input atomically stops the currently-running
    # timer (if any) before inserting its new row, so the one-active-timer
    # invariant holds even across a multi-element batch (each start closes
    # the prior). `title` defaults to "Work session" when omitted.
    # `referenceIds` carries the new `activityId` per input in input order.
    adminProjectTimersStart(inputs: [AdminProjectTimerStartInput!]!): MutationResult!
    # Stamp `endedAt = now` and write `durationSec` on the running timers.
    # Idempotent per id on an already-stopped row (left untouched); throws
    # if an id does not exist. `referenceIds` echoes the input `activityIds`.
    adminProjectTimersStop(activityIds: [ID!]!): MutationResult!

    # --- AdminProject links & files ---------------------------------------------
    # Batch create-or-update of external links associated with a project.
    # `activityId` may only be set on create; once linked, the resource
    # survives activity deletion (FK cascade-set-null). Pin toggles ride
    # this same mutation — pass the existing row with `pinned` flipped.
    # `referenceIds` echoes the row id per input in input order.
    adminProjectLinksUpsert(projectLinks: [AdminProjectLinkUpsert!]!): MutationResult!
    adminProjectLinksDelete(projectLinkIds: [ID!]!): MutationResult!

    # Batch create-or-update of file resources. The caller uploads each file
    # first via `POST /api/file-uploads` and passes the returned
    # `fileUploadId`. On delete the project-file row goes; the underlying
    # upload blob stays (cleaned up by the user-row cascade later). Pin
    # toggles ride this same mutation — pass the existing row with `pinned`
    # flipped. `referenceIds` echoes the row id per input in input order.
    adminProjectFilesUpsert(projectFiles: [AdminProjectFileUpsert!]!): MutationResult!
    adminProjectFilesDelete(projectFileIds: [ID!]!): MutationResult!

    # Overwrite a standalone workspace file's markdown body (and optionally its
    # label) in place. The underlying upload's bytes are rewritten so the
    # `fileUpload.url` stays stable across edits. `referenceIds` echoes the
    # `workspaceFileId`. Used by both the editor Save button and the assistant's
    # `workspaceFileUpdate` tool.
    adminWorkspaceFileUpdate(workspaceFileId: ID!, content: String!, label: String): MutationResult!
}

# --- Admin chat config -------------------------------------------------------
#
# Workspace assistant configuration: which Gemini model the admin composer
# defaults to, and the catalog of models available to pick from. The catalog
# is server-static (`src/server/agents/adminChatModels.ts`); the saved default
# lives in the singleton `AdminChatConfig` table. The composer renders a
# dropdown driven by `availableModels` and forwards the picked id through
# `ChatAssistantOptions.modelId`. See `docs/features/admin-chat-config.md`.

# One entry in the admin chat-model catalog. `supportedMediaTypes` drives the
# composer's file picker `accept` filter — files of types not in this list
# can't be attached when the model is selected. The list is IANA media-type
# strings (e.g. `application/pdf`,
# `application/vnd.openxmlformats-officedocument.wordprocessingml.document`).
type AdminChatModel {
    modelId: String!
    label: String!
    supportedMediaTypes: [String!]!
}

# Chat configuration surfaced to the workspace. `defaultModelId` is the saved
# default; the composer mutates it through `chatConfigDefaultModelSet` when
# the admin picks a different model.
type AdminChatConfig {
    availableModels: [AdminChatModel!]!
    defaultModelId: String!
}

extend type Admin {
    adminChatConfigFindOne: AdminChatConfig!
}

# --- Logs --------------------------------------------------------------------
#
# Workspace surface onto the `Logs` table the server writes to via
# `serverRuntime.log.*`. Read-only triage — no live tail, no delete. Gated by
# the resolver chain on `User.admin`. See `docs/features/logging.md`.

enum LogLevel {
    error
    warn
    info
    debug
}

# A single row from the `Logs` table. `context` is the JSONB blob the logger
# attached at write time — for `Error` inputs that's `{ name, stack }`.
# Surfaced verbatim as `JSON` so the viewer can pretty-print it. `sessionId`
# is the session that triggered the log; null when the logger was called
# without a session (e.g. background jobs, startup).
type Log {
    logId: ID!
    level: LogLevel!
    message: String!
    sessionId: ID
    context: JSON
    createdAt: DateTime!
}

extend type Admin {
    # Recent log rows, newest first. Server-side narrows on `level` (single
    # level only; the picker is single-select) and on a case-insensitive
    # `message` substring match — `%` / `_` in `search` are escaped so they
    # match literally. `limit` caps the result count — defaults to 200,
    # clamped at 1000 server-side so a runaway client can't OOM the API.
    adminLogFindMany(level: LogLevel, search: String, limit: Int): [Log!]!
}

extend type AdminMutation {
    # Persist the admin's chosen default chat model. Rejects ids outside the
    # catalog (`Admin.adminChatConfigFindOne.availableModels`).
    chatConfigDefaultModelSet(modelId: String!): MutationResult!
}

# --- Media -------------------------------------------------------------------
#
# `/workspace/media` — Cem's movie watchlist and favourite YouTube/podcast
# channels. Admin-only, `noindex`; the CV/public split doesn't apply, so no
# `*De`/`*En` pairs (matches Projects / Tasks). `topics` is the clustering
# axis on both entities: a free-form `text[]` whose *known* vocabulary is the
# `AdminMediaTopic` enum below — new values can be added without a schema change.
# `/workspace/software` filters channels via `Admin.media.channelsByTopic("tech")`
# for its "favourite tech YouTubers" section. See
# `docs/features/workspace-media.md`.

enum AdminMediaMovieStatus {
    watchlist
    watching
    watched
    dropped
}

enum AdminMediaPlatform {
    youtube
    twitch
    podcast
    other
}

# Known clustering vocabulary. The `topics` column accepts any string so
# ad-hoc topics work; this enum drives the UI autocomplete and typed writes.
# Adding a value is a one-line change here plus mirroring in
# `mediaTopics` (`src/server/db/schema.ts`).
enum AdminMediaTopic {
    tech
    ai
    software
    gaming
    movieCritic
    entertainment
    comedy
    science
    business
    finance
    news
    music
    sports
    lifestyle
    education
}

# A single film Cem tracks. `tmdbId` is present when the row was created via
# the TMDB search flow — the poster / release / overview fields are cached
# from TMDB and refresh on re-add. Manually-entered rows carry a null
# `tmdbId` and whatever the admin typed. `rating` is 1..10 (admin's own).
type AdminMediaMovie {
    movieId: ID!
    title: String!
    tmdbId: Int
    posterUrl: String
    backdropUrl: String
    releaseDate: Date
    runtimeMinutes: Int
    overview: String
    status: AdminMediaMovieStatus!
    rating: Int
    watchedAt: DateTime
    notes: String
    topics: [String!]!
    updatedAt: DateTime!
}

# A TV series Cem tracks. Same watch-status vocabulary as `AdminMediaMovie`, plus
# series-specific fields: `isCompleted` (show has ended) and next-season
# timing — exact `nextSeasonReleaseDate` and/or free-form
# `nextSeasonReleaseRough` ("Fall 2026"). `tmdbId` is unique-nullable like
# movies. See `docs/features/workspace-media.md`.
type AdminMediaShow {
    showId: ID!
    title: String!
    tmdbId: Int
    posterUrl: String
    backdropUrl: String
    firstAirDate: Date
    overview: String
    status: AdminMediaMovieStatus!
    rating: Int
    notes: String
    topics: [String!]!
    isCompleted: Boolean!
    nextSeasonReleaseDate: Date
    nextSeasonReleaseRough: String
    updatedAt: DateTime!
}

# A favourite YouTube channel / podcast / stream. `topics` clusters channels
# for the media page (grouped rows) and for cross-view reads
# (`Admin.media.channelsByTopic`). `priority` orders channels within a topic
# section — reorder rewrites priorities in a single txn (see
# `adminMediaChannelReorder`), matching the CV reorder pattern.
type AdminMediaChannel {
    channelId: ID!
    name: String!
    platform: AdminMediaPlatform!
    url: String!
    handle: String
    avatarUrl: String
    description: String
    topics: [String!]!
    priority: Int!
    notes: String
    updatedAt: DateTime!
}

# One TMDB movie search hit. `posterUrl` is already a fully-qualified
# `image.tmdb.org` URL (the TMDB client resolves the CDN prefix so the
# client doesn't need TMDB configuration details).
type AdminMediaTmdbMovieResult {
    tmdbId: Int!
    title: String!
    releaseDate: Date
    posterUrl: String
    overview: String
}

# One TMDB TV search hit. Same shape as `AdminMediaTmdbMovieResult` but uses
# `firstAirDate` (TMDB's TV field) instead of `releaseDate`.
type AdminMediaTmdbTvResult {
    tmdbId: Int!
    title: String!
    firstAirDate: Date
    posterUrl: String
    overview: String
}

# One YouTube channel search hit. `canonicalUrl` is pre-composed
# server-side (prefers the `@handle` form when present, falls back to the
# stable `/channel/<id>` form) so the client can drop it straight into
# `AdminMediaChannelInput.url` without knowing YouTube's URL rules.
type AdminMediaYoutubeChannelResult {
    channelId: String!
    title: String!
    handle: String
    avatarUrl: String
    description: String
    subscriberCount: Int
    canonicalUrl: String!
}

# Read namespace mounted under `Admin`. Same posture as `Admin.adminChatConfigFindOne`:
# gated once at the `Query.admin` boundary by the resolver chain on
# `User.admin`. Nothing here is public.
type AdminMediaQuery {
    adminMediaMovieFindMany: [AdminMediaMovie!]!
    adminMediaShowFindMany: [AdminMediaShow!]!
    # `topic` filters to channels whose `topics` array contains it
    # (case-sensitive). Omit or pass `null` to return every channel.
    # `/workspace/software` reads this with `topic: "tech"` to render its
    # "favourite tech YouTubers" section without duplicating channel data.
    adminMediaChannelFindMany(topic: String): [AdminMediaChannel!]!
    # Live TMDB movie search — returns at most 10 results. Empty list when
    # `TMDB_API_KEY` is unset, when TMDB is unreachable, or when `query`
    # trims to empty; the media page treats "empty" as a cue to offer the
    # manual-entry dialog.
    adminMediaTmdbFindMany(query: String!): [AdminMediaTmdbMovieResult!]!
    # Live TMDB TV search — same empty-fallback semantics as
    # `adminMediaTmdbFindMany`.
    adminMediaTmdbTvFindMany(query: String!): [AdminMediaTmdbTvResult!]!
    # Live YouTube channel search — returns at most 10 results, each
    # enriched with handle + subscriber count. Same empty-fallback
    # semantics as `adminMediaTmdbFindMany`.
    adminMediaYoutubeFindMany(query: String!): [AdminMediaYoutubeChannelResult!]!
}

extend type Admin {
    adminMediaFindOne: AdminMediaQuery!
}

input AdminMediaMovieInput {
    movieId: ID
    title: String!
    tmdbId: Int
    posterUrl: String
    backdropUrl: String
    releaseDate: Date
    runtimeMinutes: Int
    overview: String
    status: AdminMediaMovieStatus!
    rating: Int
    watchedAt: DateTime
    notes: String
    topics: [String!]!
}

input AdminMediaShowInput {
    showId: ID
    title: String!
    tmdbId: Int
    posterUrl: String
    backdropUrl: String
    firstAirDate: Date
    overview: String
    status: AdminMediaMovieStatus!
    rating: Int
    notes: String
    topics: [String!]!
    isCompleted: Boolean!
    nextSeasonReleaseDate: Date
    nextSeasonReleaseRough: String
}

input AdminMediaChannelInput {
    channelId: ID
    name: String!
    platform: AdminMediaPlatform!
    url: String!
    handle: String
    avatarUrl: String
    description: String
    topics: [String!]!
    notes: String
}

# One TMDB add request — resolves to a new (or deduped) `Movies` row.
input AdminMediaMovieAddFromTmdbInput {
    tmdbId: Int!
    status: AdminMediaMovieStatus
}

# One TMDB add request — resolves to a new (or deduped) `Shows` row.
input AdminMediaShowAddFromTmdbInput {
    tmdbId: Int!
    status: AdminMediaMovieStatus
}

extend type AdminMutation {
    # Batch create-or-edit of movies. Every row with a `movieId` is updated;
    # every row without one is inserted. `referenceIds` echoes the id per
    # input row (in input order). To mark a movie watched, upsert the row with
    # `status: watched` and `watchedAt` set.
    adminMediaMoviesUpsert(movies: [AdminMediaMovieInput!]!): MutationResult!
    adminMediaMoviesDelete(movieIds: [ID!]!): MutationResult!
    # Batch add movies by TMDB id (poster / release / runtime / overview
    # auto-filled). Rows with a matching `tmdbId` are refreshed rather than
    # duplicated. `referenceIds` echoes the resolved `movieId` per input in
    # input order. Falls back to a title-only insert when TMDB is unreachable.
    adminMediaMoviesAddFromTmdb(inputs: [AdminMediaMovieAddFromTmdbInput!]!): MutationResult!

    # Batch create-or-edit of TV series. Same shape as `adminMediaMoviesUpsert`.
    adminMediaShowsUpsert(shows: [AdminMediaShowInput!]!): MutationResult!
    adminMediaShowsDelete(showIds: [ID!]!): MutationResult!
    # Batch add series by TMDB id. Seeds `isCompleted` /
    # `nextSeasonReleaseDate` from TMDB when available; `nextSeasonReleaseRough`
    # stays admin-authored. `referenceIds` echoes the resolved `showId` per
    # input in input order.
    adminMediaShowsAddFromTmdb(inputs: [AdminMediaShowAddFromTmdbInput!]!): MutationResult!

    # Batch create-or-edit of favourite channels. `referenceIds` echoes the
    # id per input row in input order.
    adminMediaChannelsUpsert(mediaChannels: [AdminMediaChannelInput!]!): MutationResult!
    adminMediaChannelsDelete(channelIds: [ID!]!): MutationResult!
    # Rewrite `priority` on the given channel ids in array order. Callers
    # scope the list to a single topic bucket — the server does not enforce
    # single-topic membership (a channel with multiple topics is reorderable
    # under each topic section independently, and the last write wins on
    # `priority`). Matches the CV reorder shape.
    adminMediaChannelReorder(orderedIds: [ID!]!): MutationResult!
}

# --- Medical -----------------------------------------------------------------
#
# `/workspace/medical` — Cem's health journal and appointment tracker.
# Admin-only, `noindex`; no `*De`/`*En` pairs (matches Media / Inventory).
# Two surfaces backed by two tables plus a `FileUploads` join:
#
#   - `AdminMedicalRecord` — a chat-authored writeup ("red patch on forearm, four
#     days, itching"). The medical sub-agent asks clarifiers and files these
#     from the workspace assistant chat. Optionally carries photo attachments
#     (`MedicalRecordFiles` → `FileUploads`, same wire as inventory receipts).
#   - `AdminMedicalAppointment` — scheduled or completed visits with a provider.
#     Grouped by `category`. "When is my next dentist visit?" reads
#     `nextDueAt ?? lastCompletedAt + defaultCadence`; the cadence lives as
#     a static config server-side, not a table.
#
# See `docs/features/workspace-medical.md`.

enum AdminMedicalCategory {
    dentist
    gp
    dermatology
    eyes
    mentalHealth
    ent
    physio
    other
}

enum AdminMedicalAppointmentStatus {
    scheduled
    completed
    cancelled
    missed
}

enum AdminMedicalRecordSeverity {
    info
    mild
    moderate
    severe
}

# A scheduled or completed appointment. `providerName` is free-text (no
# `MedicalProvider` table in v1). `scheduledAt` is the intended time,
# `completedAt` stamps when the visit actually happened. `nextDueAt`
# overrides the category cadence when the doctor sets a specific follow-up.
type AdminMedicalAppointment {
    appointmentId: ID!
    category: AdminMedicalCategory!
    providerName: String
    title: String!
    notes: String
    scheduledAt: DateTime!
    completedAt: DateTime
    nextDueAt: DateTime
    status: AdminMedicalAppointmentStatus!
    topics: [String!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# A file attached to a medical record. Same two-step wire as inventory
# receipts: client `POST /api/file-uploads` → gets a `fileUploadId` → calls
# `medicalRecordFileAttach` (or passes it inline via `AdminMedicalRecordInput.fileUploadIds`).
type AdminMedicalRecordFile {
    recordFileId: ID!
    recordId: ID!
    fileUpload: FileUpload!
    label: String
    pinned: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# A health-journal entry. `summary` is the agent's (or admin's) structured
# writeup. `symptoms` / `bodyAreas` are free-form so the vocabulary can grow
# without migrations. `appointmentId` optionally links the record to the
# visit that produced it or a follow-up.
type AdminMedicalRecord {
    recordId: ID!
    category: AdminMedicalCategory!
    title: String!
    summary: String!
    severity: AdminMedicalRecordSeverity
    symptoms: [String!]!
    bodyAreas: [String!]!
    occurredAt: DateTime
    resolvedAt: DateTime
    appointmentId: ID
    topics: [String!]!
    files: [AdminMedicalRecordFile!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One row per `AdminMedicalCategory` for the Overview tab. `defaultCadenceMonths`
# is the static config; `lastCompletedAt` is the most recent `completed`
# appointment in that category; `nextDueAt` prefers the explicit override on
# the last completed appointment and falls back to
# `lastCompletedAt + defaultCadence`; `isOverdue = nextDueAt < now`.
# `upcoming` lists the near-term scheduled visits; `recentRecords` lists the
# last handful of records so the overview card previews recent history.
type AdminMedicalCategoryOverview {
    category: AdminMedicalCategory!
    defaultCadenceMonths: Int
    lastCompletedAt: DateTime
    nextDueAt: DateTime
    isOverdue: Boolean!
    upcoming: [AdminMedicalAppointment!]!
    recentRecords: [AdminMedicalRecord!]!
}

# Read namespace mounted under `Admin`. Gated once at the `Query.admin`
# boundary by the resolver chain on `User.admin`.
type AdminMedicalQuery {
    adminMedicalAppointmentFindMany: [AdminMedicalAppointment!]!
    adminMedicalRecordFindMany: [AdminMedicalRecord!]!
    adminMedicalCategoryOverviewFindMany: [AdminMedicalCategoryOverview!]!
}

extend type Admin {
    adminMedicalFindOne: AdminMedicalQuery!
}

input AdminMedicalAppointmentInput {
    appointmentId: ID
    category: AdminMedicalCategory!
    providerName: String
    title: String!
    notes: String
    scheduledAt: DateTime!
    completedAt: DateTime
    nextDueAt: DateTime
    status: AdminMedicalAppointmentStatus!
    topics: [String!]!
}

input AdminMedicalRecordInput {
    recordId: ID
    category: AdminMedicalCategory!
    title: String!
    summary: String!
    severity: AdminMedicalRecordSeverity
    symptoms: [String!]!
    bodyAreas: [String!]!
    occurredAt: DateTime
    resolvedAt: DateTime
    appointmentId: ID
    topics: [String!]!
    # Optional: attach these already-uploaded files to the record in the
    # same transaction. Each id must reference an existing `FileUploads`
    # row owned by the admin user. Same wire as inventory receipts —
    # the client uploads bytes first via `POST /api/file-uploads`.
    fileUploadIds: [ID!]
}

# `medicalRecordFileAttach` payload. Same two-step upload contract as
# `adminInventoryItemFilesAttach`: client uploads bytes → gets `fileUploadId` → calls this.
input AdminMedicalRecordFileAttachInput {
    recordId: ID!
    fileUploadId: ID!
    label: String
    pinned: Boolean
}

extend type AdminMutation {
    adminMedicalAppointmentsUpsert(medicalAppointments: [AdminMedicalAppointmentInput!]!): MutationResult!
    adminMedicalAppointmentsDelete(appointmentIds: [ID!]!): MutationResult!

    adminMedicalRecordsUpsert(medicalRecords: [AdminMedicalRecordInput!]!): MutationResult!
    adminMedicalRecordsDelete(recordIds: [ID!]!): MutationResult!

    adminMedicalRecordFilesAttach(inputs: [AdminMedicalRecordFileAttachInput!]!): MutationResult!
    adminMedicalRecordFilesDelete(recordFileIds: [ID!]!): MutationResult!
}

# --- Inventory ---------------------------------------------------------------
#
# `/workspace/inventory` — Cem's material assets (coffee machine, car, TV,
# monitors, …), each with warranty, a service log, receipt / photo uploads,
# and a repricing journal so a "material net worth" number can surface on
# the finances overview. Admin-only, `noindex`; matches the Media / Projects
# posture. See `docs/features/workspace-inventory.md`.

# Category taxonomy is hard-coded; new values add here + in `itemCategories`
# in `src/server/db/schema.ts`. Elevate to a table only if categories ever
# need to be user-editable.
enum AdminInventoryItemCategory {
    electronics
    appliance
    kitchen
    furniture
    vehicle
    clothing
    tool
    sports
    other
}

enum AdminInventoryItemCondition {
    new
    likeNew
    good
    fair
    poor
}

enum AdminInventoryItemDisposalState {
    owned
    sold
    gifted
    lost
    disposed
}

enum AdminInventoryItemServiceKind {
    service
    repair
    replacement
    other
}

enum AdminInventoryItemFileKind {
    photo
    receipt
    warranty
    manual
    invoice
    other
}

# One tracked possession. `currentValueCents` is the cached snapshot of the
# most recent `AdminInventoryItemValuation` — the `adminInventoryItemsReprice` mutation writes the journal
# row and this cached column in one transaction, so the list surface and
# `materialNetWorthCents` never need to `MAX(valuedAt)` at read time.
#
# `valuations` / `serviceEntries` / `files` are populated on the singular
# `adminInventoryItemFindOne(itemId)` fetch. On the plural `adminInventoryItemFindMany`
# list they resolve to `[]` — mirrors how `adminProjectFindMany` returns projects
# without their tasks and `adminProjectFindOne` returns them with. Detail-view
# callers use the singular query.
type AdminInventoryItem {
    itemId: ID!
    categoryKey: AdminInventoryItemCategory!
    name: String!
    brand: String
    model: String
    serialNumber: String
    purchasedAt: Date
    purchasePriceCents: Int
    currentValueCents: Int
    condition: AdminInventoryItemCondition
    disposalState: AdminInventoryItemDisposalState!
    disposedAt: DateTime
    warrantyEndsAt: Date
    warrantyProvider: String
    warrantyNotes: String
    notes: String
    valuations: [AdminInventoryItemValuation!]!
    serviceEntries: [AdminInventoryItemServiceEntry!]!
    files: [AdminInventoryItemFile!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One repricing entry in the item's journal. `valuedAt` defaults to insert
# time but is settable so a back-dated appraisal reads correctly on the
# sparkline. Ordered `valuedAt DESC` on read.
type AdminInventoryItemValuation {
    valuationId: ID!
    valueCents: Int!
    valuedAt: DateTime!
    note: String
}

# One service / repair / replacement event on an item. `nextDueAt` powers the
# "next service due" reminder — independent of warranty (which lives on the
# item itself).
type AdminInventoryItemServiceEntry {
    serviceEntryId: ID!
    kind: AdminInventoryItemServiceKind!
    performedAt: Date!
    vendor: String
    costCents: Int
    notes: String
    nextDueAt: Date
    # Files attached specifically to this entry (e.g. the invoice). The
    # broader `AdminInventoryItem.files` list also contains these — this field is the
    # scoped view.
    files: [AdminInventoryItemFile!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# A file attached to an item. Wraps the shared `FileUpload` store with
# inventory metadata (kind, pin state, optional service-entry link). The
# `fileUpload.url` field is the download path.
type AdminInventoryItemFile {
    itemFileId: ID!
    itemId: ID!
    serviceEntryId: ID
    fileUpload: FileUpload!
    label: String
    kind: AdminInventoryItemFileKind!
    pinned: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Read namespace mounted under `Admin`. Gated once at the `Query.admin`
# boundary by the resolver chain on `User.admin`.
type AdminInventoryQuery {
    # All tracked items. Disposed / sold / gifted / lost rows are hidden by
    # default so the list surface stays focused on currently-owned things;
    # `includeDisposed: true` returns the full history for the "All" filter.
    adminInventoryItemFindMany(includeDisposed: Boolean = false): [AdminInventoryItem!]!
    # Single item by id, loaded fully (valuations, service entries, files).
    # Null when the id does not exist.
    adminInventoryItemFindOne(itemId: ID!): AdminInventoryItem
    # Sum of `currentValueCents` over items with `disposalState = 'owned'`.
    # Drives the overview strip and the future finances-page cross-reference
    # tile. Nullable columns count as 0.
    adminInventoryMaterialNetWorthCentsFindOne: Int!
    # Items whose warranty ends within the given window. Ordered
    # `warrantyEndsAt ASC` so the soonest expirations sit on top of the
    # overview list.
    adminInventoryItemUpcomingWarrantyFindMany(withinDays: Int = 90): [AdminInventoryItem!]!
}

extend type Admin {
    adminInventoryFindOne: AdminInventoryQuery!
}

input AdminInventoryItemInput {
    itemId: ID
    categoryKey: AdminInventoryItemCategory!
    name: String!
    brand: String
    model: String
    serialNumber: String
    purchasedAt: Date
    purchasePriceCents: Int
    condition: AdminInventoryItemCondition
    warrantyEndsAt: Date
    warrantyProvider: String
    warrantyNotes: String
    notes: String
    # Disposal is a plain field-set carried on the upsert — there is no
    # separate `itemDispose` mutation. Omitted on create defaults to `owned`
    # with a null stamp. `disposedAt` is forced null whenever `disposalState`
    # is `owned`, so reverting a disposed item clears its stamp. A plain
    # field edit preserves the current state because the caller spreads the
    # existing row (which carries `disposalState` + `disposedAt`).
    disposalState: AdminInventoryItemDisposalState
    disposedAt: DateTime
}

input AdminInventoryItemServiceEntryInput {
    serviceEntryId: ID
    itemId: ID!
    kind: AdminInventoryItemServiceKind!
    performedAt: Date!
    vendor: String
    costCents: Int
    notes: String
    nextDueAt: Date
}

# One repricing instruction for `adminInventoryItemsReprice`. Kept separate from
# `AdminInventoryItemInput` because a reprice is more than a field-set — it appends an
# `ItemValuations` journal row and updates the cached `currentValueCents` in
# one transaction. `valuedAt` defaults to now when omitted.
input AdminInventoryItemRepriceInput {
    itemId: ID!
    valueCents: Int!
    valuedAt: DateTime
    note: String
}

# `adminInventoryItemFilesAttach` payload. The client first uploads bytes via
# `POST /api/file-uploads`, then calls this mutation with the returned
# `fileUploadId` — same two-step shape as `adminProjectFilesUpsert`.
input AdminInventoryItemFileAttachInput {
    itemId: ID!
    serviceEntryId: ID
    fileUploadId: ID!
    label: String
    kind: AdminInventoryItemFileKind!
    pinned: Boolean
}

# Edit-only payload for `adminInventoryItemFilesUpsert`. Every input targets an existing
# item-file row by `itemFileId` — this mutation never creates rows (use
# `adminInventoryItemFilesAttach` for that). The pin toggle in the UI collapses into this:
# pass the existing row's id with the flipped `pinned`.
input AdminInventoryItemFileUpsert {
    itemFileId: ID!
    label: String
    pinned: Boolean
}

extend type AdminMutation {
    adminInventoryItemsUpsert(items: [AdminInventoryItemInput!]!): MutationResult!
    adminInventoryItemsDelete(itemIds: [ID!]!): MutationResult!
    # Journal a new valuation and update the cached `currentValueCents` per
    # input, all in one transaction. `referenceIds` echoes the `itemId` per
    # input in input order.
    adminInventoryItemsReprice(inputs: [AdminInventoryItemRepriceInput!]!): MutationResult!

    adminInventoryItemServiceEntriesUpsert(itemServiceEntries: [AdminInventoryItemServiceEntryInput!]!): MutationResult!
    adminInventoryItemServiceEntriesDelete(serviceEntryIds: [ID!]!): MutationResult!

    adminInventoryItemFilesAttach(inputs: [AdminInventoryItemFileAttachInput!]!): MutationResult!
    adminInventoryItemFilesDelete(itemFileIds: [ID!]!): MutationResult!
    # Edit existing item-file rows (label / pin state). Never creates.
    adminInventoryItemFilesUpsert(itemFiles: [AdminInventoryItemFileUpsert!]!): MutationResult!
}

# --- Travel -----------------------------------------------------------------
#
# `/workspace/travel` — Cem's trip planner. Three-tier: `AdminTravelTrip` holds
# meta (destination, dates, transport, accommodation), `AdminTravelTripDay` is a
# first-class per-day bucket ("Day 3 in Rome"), `AdminTravelTripActivity` is a
# single item on that day. `AdminTravelTripPackingItem` is a trip-scoped
# checklist grouped by free-text `category`. Admin-only, `noindex`; no
# `*De`/`*En` pairs. Types, inputs, and tables all carry the `AdminTravel`
# entity-access-path prefix — see `docs/conventions.md` ("Type & input naming").
#
# The three-tier shape exists so the AI assistant can persist a day-by-day
# itinerary from a chat and future chats read it from the DB instead of the
# transcript — the whole reason the feature exists. See
# `docs/features/workspace-travel.md`.

# Planning intent only. Whether a trip is upcoming / underway / past is NOT a
# status value — it is derived from the `startsOn`/`endsOn` range so it can
# never go stale. `draft` = still sketching, `planned` = confirmed it's
# happening, `cancelled` = was going to happen, called off.
enum AdminTravelTripStatus {
    draft
    planned
    cancelled
}

enum AdminTravelTransportMode {
    flight
    train
    car
    ferry
    mixed
}

# One activity within an `AdminTravelTripDay`. `startsAt` / `endsAt` are
# wall-clock strings (`HH:MM` or `HH:MM:SS`) — a single tz would be a lie for
# a location-scoped plan. Ordered by `position ASC` within a day; the client
# also honours times when both `startsAt` values are set.
type AdminTravelTripActivity {
    tripActivityId: ID!
    tripDayId: ID!
    position: Int!
    startsAt: String
    endsAt: String
    title: String!
    location: String
    url: String
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One day of a trip. `dayNumber` is the 1-based ordinal the agent addresses
# ("Day 3") and the single ordering key. `date` is DERIVED and read-only —
# the server computes it from the trip's `startsOn` plus `dayNumber`, so it is
# null for a dateless trip and cannot be set through the input. `summary` is
# the paragraph the agent writes to frame the day; `activities` is ordered by
# position ascending.
type AdminTravelTripDay {
    tripDayId: ID!
    tripId: ID!
    dayNumber: Int!
    date: Date
    title: String
    summary: String
    activities: [AdminTravelTripActivity!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One row on the trip's packing checklist. `category` is free text so the
# agent can invent a new bucket without a migration; the UI groups by it.
type AdminTravelTripPackingItem {
    tripPackingItemId: ID!
    tripId: ID!
    category: String!
    label: String!
    quantity: Int!
    packed: Boolean!
    position: Int!
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# A trip. On the list surface `days` / `packingItems` may still resolve fully
# so the cards can show progress badges without a second fetch — the payload
# stays small because trip volume is low (dozens, not thousands).
type AdminTravelTrip {
    tripId: ID!
    title: String!
    destination: String!
    startsOn: Date
    endsOn: Date
    status: AdminTravelTripStatus!
    transportMode: AdminTravelTransportMode
    accommodation: String
    notes: String
    days: [AdminTravelTripDay!]!
    packingItems: [AdminTravelTripPackingItem!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Read namespace mounted under `Admin`. Gated once at the `Query.admin`
# boundary by the resolver chain on `User.admin`.
type AdminTravelQuery {
    # All trips, sorted `startsOn NULLS LAST, createdAt DESC`.
    adminTravelTripFindMany: [AdminTravelTrip!]!
    # Single trip by id — null when the id does not exist.
    adminTravelTripFindOne(tripId: ID!): AdminTravelTrip
}

extend type Admin {
    adminTravelFindOne: AdminTravelQuery!
}

input AdminTravelTripInput {
    tripId: ID
    title: String!
    destination: String!
    startsOn: Date
    endsOn: Date
    status: AdminTravelTripStatus!
    transportMode: AdminTravelTransportMode
    accommodation: String
    notes: String
}

input AdminTravelTripDayInput {
    tripDayId: ID
    tripId: ID!
    dayNumber: Int!
    title: String
    summary: String
}

input AdminTravelTripActivityInput {
    tripActivityId: ID
    tripDayId: ID!
    position: Int
    startsAt: String
    endsAt: String
    title: String!
    location: String
    url: String
    notes: String
}

input AdminTravelTripPackingItemInput {
    tripPackingItemId: ID
    tripId: ID!
    category: String!
    label: String!
    quantity: Int
    packed: Boolean
    position: Int
    notes: String
}

extend type AdminMutation {
    adminTravelTripsUpsert(trips: [AdminTravelTripInput!]!): MutationResult!
    adminTravelTripsDelete(tripIds: [ID!]!): MutationResult!

    adminTravelTripDaysUpsert(tripDays: [AdminTravelTripDayInput!]!): MutationResult!
    adminTravelTripDaysDelete(tripDayIds: [ID!]!): MutationResult!

    adminTravelTripActivitiesUpsert(tripActivities: [AdminTravelTripActivityInput!]!): MutationResult!
    adminTravelTripActivitiesDelete(tripActivityIds: [ID!]!): MutationResult!

    adminTravelTripPackingItemsUpsert(tripPackingItems: [AdminTravelTripPackingItemInput!]!): MutationResult!
    adminTravelTripPackingItemsDelete(tripPackingItemIds: [ID!]!): MutationResult!
}

# --- Finances ---------------------------------------------------------------
#
# `/workspace/finances` — Cem's recurring costs (rent, insurance,
# subscriptions, transport, …) plus a Sankey visualisation. Admin-only,
# `noindex`; no `*De`/`*En`. `amountCents` is per-`cadence`, so the Monthly /
# Yearly toggle on the page is a deterministic projection over the same rows
# (no dated transactions in v1). See `docs/features/workspace-finances.md`.

enum AdminFinancesRecurringCostCategory {
    housing
    connectivity
    transport
    insurance
    subscriptionsEntertainment
    subscriptionsWork
    memberships
    donations
    household
    savingsGeneral
    savingsVacation
    other
}

enum AdminFinancesCadence {
    monthly
    yearly
}

# One recurring charge. `active = false` hides the row from the Sankey and
# the totals without deleting the history (paused subscription, sold car).
# `startsOn` / `endsOn` are informational for v1 and do not participate in
# any projection.
type AdminFinancesRecurringCost {
    costId: ID!
    name: String!
    categoryKey: AdminFinancesRecurringCostCategory!
    amountCents: Int!
    cadence: AdminFinancesCadence!
    currency: String!
    notes: String
    active: Boolean!
    startsOn: Date
    endsOn: Date
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Read namespace mounted under `Admin`. Gated once at the `Query.admin`
# boundary by the resolver chain on `User.admin`. The two `Cents`
# aggregates are computed in the resolver from the active recurring costs
# — the Sankey and the overview strip both read them directly.
type AdminFinancesQuery {
    adminFinancesRecurringCostFindMany: [AdminFinancesRecurringCost!]!
    adminFinancesMonthlyNetIncomeCentsFindOne: Int
    adminFinancesMonthlyExpensesCentsFindOne: Int!
    adminFinancesYearlyExpensesCentsFindOne: Int!
}

extend type Admin {
    adminFinancesFindOne: AdminFinancesQuery!
}

input AdminFinancesRecurringCostInput {
    costId: ID
    name: String!
    categoryKey: AdminFinancesRecurringCostCategory!
    amountCents: Int!
    cadence: AdminFinancesCadence!
    currency: String
    notes: String
    active: Boolean
    startsOn: Date
    endsOn: Date
}

extend type AdminMutation {
    # Batch create-or-edit of recurring costs. Every row with a `costId` is
    # updated; every row without one is inserted. `referenceIds` echoes the
    # id per input row in input order. Single-item edits (the dialog) pass a
    # one-element array. Pausing a cost rides this same upsert — pass the row
    # back with `active` flipped.
    adminFinancesRecurringCostsUpsert(financeRecurringCosts: [AdminFinancesRecurringCostInput!]!): MutationResult!
    adminFinancesRecurringCostsDelete(costIds: [ID!]!): MutationResult!
    # Singleton setter — one settings row per admin. Pass `amountCents: null`
    # to clear the baseline. The `userUpdates` subscription re-renders the
    # totals; there is nothing to batch here.
    adminFinancesMonthlyNetIncomeSet(amountCents: Int): MutationResult!
}

# --- Nutrition --------------------------------------------------------------
#
# `/workspace/nutrition` — a cookbook (`AdminNutritionRecipe`), a *soft* weekly meal plan
# (`AdminNutritionMealPlanEntry` — only filled slots exist), and a food/drink diary
# (`AdminNutritionFoodLogEntry`) the page rolls up into an end-of-week overview. Admin-only,
# `noindex`; no `*De`/`*En`. See `docs/features/workspace-nutrition.md`.

# When a dish is eaten, planned, or logged. Shared across all three nutrition
# entities so the assistant's "snack idea" ask, the plan grid, and the diary
# speak one vocabulary.
enum AdminNutritionMealType {
    breakfast
    lunch
    dinner
    snack
    other
}

# Distinguishes something eaten from something drunk so the weekly overview
# can split intake.
enum AdminNutritionFoodLogKind {
    food
    drink
}

# One cookbook entry. `isFavorite` + `lastMadeAt` are what let the nutrition
# sub-agent suggest a dish Cem likes and hasn't made recently. `ingredients`
# and `tags` are free-form arrays. `rating` is 1..10.
type AdminNutritionRecipe {
    recipeId: ID!
    title: String!
    mealType: AdminNutritionMealType!
    ingredients: [String!]!
    steps: String
    tags: [String!]!
    isFavorite: Boolean!
    rating: Int
    prepTimeMinutes: Int
    servings: Int
    sourceUrl: String
    notes: String
    lastMadeAt: DateTime
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One soft-plan slot: a `(date, mealType)` cell that either references a
# `recipe` or carries a free-text `customText` idea. `recipe` is null when the
# planned dish is not in the cookbook (or was deleted).
type AdminNutritionMealPlanEntry {
    entryId: ID!
    date: Date!
    mealType: AdminNutritionMealType!
    recipe: AdminNutritionRecipe
    customText: String
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One diary row: something eaten or drunk at `consumedAt`. `recipe` optionally
# links back to a cooked dish.
type AdminNutritionFoodLogEntry {
    logId: ID!
    consumedAt: DateTime!
    mealType: AdminNutritionMealType!
    kind: AdminNutritionFoodLogKind!
    description: String!
    recipe: AdminNutritionRecipe
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One tracked supplement. The exact per-serving composition lives in `nutrients`
# — filled by the `adminNutritionSupplementResearch` action (grounded web search) and
# confirmed by Cem before saving. `researchedAt` is set when the composition
# came from that AI fill; `sourceUrl` is the product page it was read from.
type AdminNutritionSupplement {
    supplementId: ID!
    name: String!
    brand: String
    # Free text as printed on the label, e.g. "2 capsules" or "1 scoop (5 g)".
    servingSize: String
    servingsPerContainer: Int
    sourceUrl: String
    notes: String
    researchedAt: DateTime
    # Per-serving composition, ordered as on the label (`sortOrder`).
    nutrients: [AdminNutritionSupplementNutrient!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One nutrient line on a supplement's facts panel. `amount` is a string so it
# tolerates "<1", "trace", and ranges printed verbatim on the label.
type AdminNutritionSupplementNutrient {
    nutrientId: ID!
    name: String!
    amount: String
    unit: String
    percentDailyValue: Int
    sortOrder: Int!
}

# The proposed composition returned by `adminNutritionSupplementResearch`. Non-persisted — the
# dialog (or the sub-agent) reviews it and feeds the confirmed values into
# `adminNutritionSupplementsUpsert`. `found` is false when the product could not be
# identified; in that case `nutrients` is empty and no amounts are invented.
type AdminNutritionSupplementResearchResult {
    found: Boolean!
    brand: String
    servingSize: String
    servingsPerContainer: Int
    sourceUrl: String
    notes: String
    nutrients: [AdminNutritionSupplementNutrientProposal!]!
    # One-line note on what was found (or why nothing was), for the UI / agent.
    summary: String!
}

type AdminNutritionSupplementNutrientProposal {
    name: String!
    amount: String
    unit: String
    percentDailyValue: Int
}

# Read namespace mounted under `Admin`. Gated once at the `Query.admin`
# boundary by the resolver chain on `User.admin`. Meal-plan and diary lists
# return everything and the page slices to the visible week client-side —
# keeping the whole namespace inside the args-free seed-and-subscribe fragment
# (matching travel / medical). Personal-scale volume makes fetch-all fine.
type AdminNutritionQuery {
    # Cookbook. Optional filters: `mealType` narrows to one meal, `favorite`
    # to starred recipes. Ordered `isFavorite DESC, title ASC`.
    adminNutritionRecipeFindMany(mealType: AdminNutritionMealType, favorite: Boolean): [AdminNutritionRecipe!]!
    # Every soft-plan slot, ordered `date ASC, mealType`. The page filters to
    # the selected week.
    adminNutritionMealPlanFindMany: [AdminNutritionMealPlanEntry!]!
    # Every diary entry, newest first (`consumedAt DESC`). The page filters to
    # the selected week and rolls up the end-of-week overview.
    adminNutritionFoodLogFindMany: [AdminNutritionFoodLogEntry!]!
    # Every tracked supplement, ordered `name ASC`, each with its per-serving
    # nutrient rows ordered by `sortOrder`.
    adminNutritionSupplementFindMany: [AdminNutritionSupplement!]!
}

extend type Admin {
    adminNutritionFindOne: AdminNutritionQuery!
}

input AdminNutritionRecipeInput {
    recipeId: ID
    title: String!
    mealType: AdminNutritionMealType!
    ingredients: [String!]
    steps: String
    tags: [String!]
    isFavorite: Boolean
    rating: Int
    prepTimeMinutes: Int
    servings: Int
    sourceUrl: String
    notes: String
    # ISO-8601 timestamp. Set when Cem last cooked the dish; drives the
    # sub-agent's "not made recently" suggestion ranking.
    lastMadeAt: DateTime
}

input AdminNutritionMealPlanEntryInput {
    entryId: ID
    date: Date!
    mealType: AdminNutritionMealType!
    # Reference an existing cookbook recipe, or leave null and use `customText`.
    recipeId: ID
    customText: String
    notes: String
}

input AdminNutritionFoodLogEntryInput {
    logId: ID
    # ISO-8601 timestamp of when it was consumed.
    consumedAt: DateTime!
    mealType: AdminNutritionMealType!
    kind: AdminNutritionFoodLogKind!
    description: String!
    recipeId: ID
    notes: String
}

input AdminNutritionSupplementNutrientInput {
    name: String!
    amount: String
    unit: String
    percentDailyValue: Int
    # Position on the label; the replace falls back to array order when omitted.
    sortOrder: Int
}

input AdminNutritionSupplementInput {
    supplementId: ID
    name: String!
    brand: String
    servingSize: String
    servingsPerContainer: Int
    sourceUrl: String
    notes: String
    # ISO-8601 timestamp. Set when the composition came from the research
    # action; leave null for a purely hand-entered supplement.
    researchedAt: DateTime
}

input AdminNutritionSupplementResearchInput {
    name: String!
    brand: String
}

extend type AdminMutation {
    # Batch create-or-edit. Every row with an id is updated; every row without
    # one is inserted. `referenceIds` echoes the id per input row in input
    # order. Single-item edits (dialogs, the diary composer) pass a one-element
    # array — there is no parallel singular path.
    adminNutritionRecipesUpsert(recipes: [AdminNutritionRecipeInput!]!): MutationResult!
    adminNutritionRecipesDelete(recipeIds: [ID!]!): MutationResult!

    adminNutritionMealPlanEntriesUpsert(mealPlanEntries: [AdminNutritionMealPlanEntryInput!]!): MutationResult!
    adminNutritionMealPlanEntriesDelete(entryIds: [ID!]!): MutationResult!

    adminNutritionFoodLogEntriesUpsert(foodLogEntries: [AdminNutritionFoodLogEntryInput!]!): MutationResult!
    adminNutritionFoodLogEntriesDelete(logIds: [ID!]!): MutationResult!

    # Batch create-or-edit of supplements. Every row with a `supplementId` is
    # updated; every row without one is inserted. `referenceIds` echoes the
    # supplement id per input row in input order, so the caller can pass a new
    # id straight into `adminNutritionSupplementNutrientsReplace`. Nutrient rows are written
    # separately (see below) — a supplement and its composition are two calls,
    # mirroring the parent/child split used by travel and inventory.
    adminNutritionSupplementsUpsert(supplements: [AdminNutritionSupplementInput!]!): MutationResult!
    adminNutritionSupplementsDelete(supplementIds: [ID!]!): MutationResult!

    # Replace one supplement's entire per-serving composition with `nutrients`
    # (pass [] to clear it). `sortOrder` defaults to array position when omitted.
    adminNutritionSupplementNutrientsReplace(supplementId: ID!, nutrients: [AdminNutritionSupplementNutrientInput!]!): MutationResult!

    # AI web-research action. Grounded search for the named product's official
    # supplement facts, returning a proposed composition for review. Persists
    # NOTHING — the caller confirms and then calls `adminNutritionSupplementsUpsert` +
    # `adminNutritionSupplementNutrientsReplace`.
    adminNutritionSupplementResearch(input: AdminNutritionSupplementResearchInput!): AdminNutritionSupplementResearchResult!
}

# --- Fitness ----------------------------------------------------------------
#
# `/workspace/fitness` — an exercise catalog (`AdminFitnessExercise`), reusable routines
# (`AdminFitnessWorkoutRoutine` + `AdminFitnessWorkoutRoutineItem`), and the gym log (`AdminFitnessWorkoutSession`
# + `AdminFitnessWorkoutSet`, weight × reps per set). Admin-only, `noindex`; no `*De`/`*En`.
# See `docs/features/workspace-fitness.md`.

enum AdminFitnessMuscleGroup {
    chest
    back
    legs
    shoulders
    arms
    core
    fullBody
    cardio
    other
}

enum AdminFitnessEquipmentType {
    barbell
    dumbbell
    machine
    cable
    bodyweight
    kettlebell
    other
}

# One movement in the catalog. Sessions and routines reference it.
type AdminFitnessExercise {
    exerciseId: ID!
    name: String!
    muscleGroup: AdminFitnessMuscleGroup!
    equipment: AdminFitnessEquipmentType
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One planned exercise within a routine, with optional targets. `exercise`
# resolves the referenced catalog row; `items` on a routine are ordered by
# `position` ascending.
type AdminFitnessWorkoutRoutineItem {
    routineItemId: ID!
    routineId: ID!
    exercise: AdminFitnessExercise!
    position: Int!
    targetSets: Int
    targetReps: Int
    targetWeight: Float
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# A reusable workout template ("Push day"). Starting a session from it seeds
# `WorkoutSets` from the routine's items.
type AdminFitnessWorkoutRoutine {
    routineId: ID!
    name: String!
    notes: String
    position: Int!
    items: [AdminFitnessWorkoutRoutineItem!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One logged set: `weight` × `reps`, optional `rpe`, and an `isWarmup` flag so
# warmups don't pollute PR math. `exercise` resolves the catalog row.
type AdminFitnessWorkoutSet {
    setId: ID!
    sessionId: ID!
    exercise: AdminFitnessExercise!
    position: Int!
    weight: Float
    reps: Int
    rpe: Int
    isWarmup: Boolean!
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

# One gym session. `routineId` links the routine it was seeded from (null when
# ad-hoc, or if that routine was later deleted). `sets` are ordered by
# `position` ascending.
type AdminFitnessWorkoutSession {
    sessionId: ID!
    date: Date!
    title: String
    routineId: ID
    durationMinutes: Int
    notes: String
    sets: [AdminFitnessWorkoutSet!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Read namespace mounted under `Admin`. Gated once at the `Query.admin`
# boundary by the resolver chain on `User.admin`.
type AdminFitnessQuery {
    # AdminFitnessExercise catalog, ordered `muscleGroup, name ASC`.
    adminFitnessExerciseFindMany: [AdminFitnessExercise!]!
    # All routines with their items pre-joined, ordered `position ASC`.
    adminFitnessRoutineFindMany: [AdminFitnessWorkoutRoutine!]!
    # Sessions with their sets pre-joined, ordered `date DESC, createdAt DESC`.
    adminFitnessSessionFindMany: [AdminFitnessWorkoutSession!]!
}

extend type Admin {
    adminFitnessFindOne: AdminFitnessQuery!
}

input AdminFitnessExerciseInput {
    exerciseId: ID
    name: String!
    muscleGroup: AdminFitnessMuscleGroup!
    equipment: AdminFitnessEquipmentType
    notes: String
}

input AdminFitnessWorkoutRoutineInput {
    routineId: ID
    name: String!
    notes: String
    position: Int
}

input AdminFitnessWorkoutRoutineItemInput {
    routineItemId: ID
    routineId: ID!
    exerciseId: ID!
    position: Int
    targetSets: Int
    targetReps: Int
    targetWeight: Float
    notes: String
}

input AdminFitnessWorkoutSessionInput {
    sessionId: ID
    date: Date!
    title: String
    routineId: ID
    durationMinutes: Int
    notes: String
}

input AdminFitnessWorkoutSetInput {
    setId: ID
    sessionId: ID!
    exerciseId: ID!
    position: Int
    weight: Float
    reps: Int
    rpe: Int
    isWarmup: Boolean
    notes: String
}

extend type AdminMutation {
    # Batch create-or-edit. Every row with an id is updated; every row without
    # one is inserted. `referenceIds` echoes the id per input row in input
    # order — logging a workout is `adminFitnessWorkoutSessionsUpsert` (one session) then
    # `adminFitnessWorkoutSetsUpsert` (every set) using the session's `referenceIds` as the
    # parent id. Single-item edits pass a one-element array.
    adminFitnessExercisesUpsert(exercises: [AdminFitnessExerciseInput!]!): MutationResult!
    adminFitnessExercisesDelete(exerciseIds: [ID!]!): MutationResult!

    adminFitnessWorkoutRoutinesUpsert(workoutRoutines: [AdminFitnessWorkoutRoutineInput!]!): MutationResult!
    adminFitnessWorkoutRoutinesDelete(routineIds: [ID!]!): MutationResult!

    adminFitnessWorkoutRoutineItemsUpsert(workoutRoutineItems: [AdminFitnessWorkoutRoutineItemInput!]!): MutationResult!
    adminFitnessWorkoutRoutineItemsDelete(routineItemIds: [ID!]!): MutationResult!

    adminFitnessWorkoutSessionsUpsert(workoutSessions: [AdminFitnessWorkoutSessionInput!]!): MutationResult!
    adminFitnessWorkoutSessionsDelete(sessionIds: [ID!]!): MutationResult!

    adminFitnessWorkoutSetsUpsert(workoutSets: [AdminFitnessWorkoutSetInput!]!): MutationResult!
    adminFitnessWorkoutSetsDelete(setIds: [ID!]!): MutationResult!
}

# --- Tax --------------------------------------------------------------------
# Organises a German tax return: a tax year holds income sources (one per
# Anlage / employer), deductible expenses (with receipt files), and a document
# checklist. Admin-only, gated once at `Query.admin` / `Mutation.admin`. This
# is a collection/organisation tool, not a tax calculator — no advice.

enum AdminTaxYearStatus {
    open
    collecting
    filing
    submitted
    closed
}

enum AdminTaxIncomeKind {
    employment
    selfEmployment
    business
    minijob
    capital
    other
}

enum AdminTaxExpenseCategory {
    businessExpense
    workRelated
    specialExpenses
    insurance
    extraordinary
    homeOffice
    other
}

enum AdminTaxDocumentKind {
    lohnsteuerbescheinigung
    euer
    minijobConfirmation
    insuranceStatement
    donationReceipt
    bankStatement
    other
}

enum AdminTaxDocumentStatus {
    needed
    received
    notApplicable
}

enum AdminTaxFileKind {
    receipt
    statement
    scan
    other
}

type AdminTaxFile {
    taxFileId: ID!
    taxYearId: ID!
    expenseId: ID
    documentId: ID
    fileUpload: FileUpload!
    label: String
    kind: AdminTaxFileKind!
    pinned: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

type AdminTaxIncomeSource {
    incomeSourceId: ID!
    kind: AdminTaxIncomeKind!
    label: String!
    grossAmountCents: Int
    notes: String
    createdAt: DateTime!
    updatedAt: DateTime!
}

type AdminTaxExpense {
    expenseId: ID!
    incomeSourceId: ID
    categoryKey: AdminTaxExpenseCategory!
    description: String!
    amountCents: Int!
    incurredOn: Date
    deductible: Boolean!
    notes: String
    files: [AdminTaxFile!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

type AdminTaxDocument {
    documentId: ID!
    kind: AdminTaxDocumentKind!
    title: String!
    status: AdminTaxDocumentStatus!
    notes: String
    files: [AdminTaxFile!]!
    createdAt: DateTime!
    updatedAt: DateTime!
}

type AdminTaxYear {
    taxYearId: ID!
    year: Int!
    status: AdminTaxYearStatus!
    filingDeadline: Date
    submittedAt: DateTime
    notes: String
    incomeSources: [AdminTaxIncomeSource!]!
    expenses: [AdminTaxExpense!]!
    documents: [AdminTaxDocument!]!
    "Sum of `grossAmountCents` across income sources (nulls treated as 0)."
    totalIncomeCents: Int!
    "Sum of `amountCents` across expenses where `deductible` is true."
    totalDeductibleCents: Int!
    createdAt: DateTime!
    updatedAt: DateTime!
}

type AdminTaxQuery {
    "Every tax year with its income sources, expenses, documents, and computed totals, newest year first."
    adminTaxYearFindMany: [AdminTaxYear!]!
}

extend type Admin {
    adminTaxFindOne: AdminTaxQuery!
}

input AdminTaxYearInput {
    "Omit to create a new year; supply to update an existing one."
    taxYearId: ID
    "The calendar year the return covers, e.g. 2025. Must be unique."
    year: Int!
    status: AdminTaxYearStatus
    "Filing deadline as an ISO date (yyyy-mm-dd), e.g. 2026-07-31."
    filingDeadline: Date
    notes: String
}

input AdminTaxIncomeSourceInput {
    "Omit to create; supply to update."
    incomeSourceId: ID
    taxYearId: ID!
    "Which Anlage this income belongs to: employment=Anlage N, selfEmployment=Anlage S, business=Anlage G, minijob=geringfügige Beschäftigung, capital=Anlage KAP."
    kind: AdminTaxIncomeKind!
    "Human label, e.g. 'SAP – Festanstellung' or 'Freelance-Entwicklung'."
    label: String!
    "Gross income in cents (e.g. 4500000 for 45.000 €). Omit if not yet known."
    grossAmountCents: Int
    notes: String
}

input AdminTaxExpenseInput {
    "Omit to create; supply to update."
    expenseId: ID
    taxYearId: ID!
    "Optional link to the income source this expense offsets (Betriebsausgabe ↔ selfEmployment, Werbungskosten ↔ employment)."
    incomeSourceId: ID
    "businessExpense=Betriebsausgabe, workRelated=Werbungskosten, specialExpenses=Sonderausgaben, insurance=Vorsorgeaufwendungen, extraordinary=außergewöhnliche Belastung, homeOffice=Homeoffice-Pauschale."
    categoryKey: AdminTaxExpenseCategory!
    "What the expense was, e.g. 'MacBook Pro' or 'Fahrtkosten Januar'."
    description: String!
    "Amount in cents (e.g. 89900 for 899,00 €)."
    amountCents: Int!
    "When the expense was incurred, ISO date (yyyy-mm-dd)."
    incurredOn: Date
    "Whether this counts toward the deductible total. Defaults to true."
    deductible: Boolean
    notes: String
}

input AdminTaxDocumentInput {
    "Omit to create; supply to update (e.g. to flip status to received)."
    documentId: ID
    taxYearId: ID!
    kind: AdminTaxDocumentKind!
    "Checklist label, e.g. 'Lohnsteuerbescheinigung 2025'."
    title: String!
    status: AdminTaxDocumentStatus
    notes: String
}

input AdminTaxFileAttachInput {
    taxYearId: ID!
    "Optional: attach as a receipt for this expense."
    expenseId: ID
    "Optional: attach as a scan of this checklist document."
    documentId: ID
    fileUploadId: ID!
    label: String
    kind: AdminTaxFileKind!
    pinned: Boolean
}

input AdminTaxFileUpsert {
    taxFileId: ID!
    label: String
    pinned: Boolean
}

extend type AdminMutation {
    "Create or update tax years. Inserting a new year also seeds its default document checklist."
    adminTaxYearsUpsert(taxYears: [AdminTaxYearInput!]!): MutationResult!
    adminTaxYearsDelete(taxYearIds: [ID!]!): MutationResult!

    adminTaxIncomeSourcesUpsert(taxIncomeSources: [AdminTaxIncomeSourceInput!]!): MutationResult!
    adminTaxIncomeSourcesDelete(incomeSourceIds: [ID!]!): MutationResult!

    adminTaxExpensesUpsert(taxExpenses: [AdminTaxExpenseInput!]!): MutationResult!
    adminTaxExpensesDelete(expenseIds: [ID!]!): MutationResult!

    adminTaxDocumentsUpsert(taxDocuments: [AdminTaxDocumentInput!]!): MutationResult!
    adminTaxDocumentsDelete(documentIds: [ID!]!): MutationResult!

    adminTaxFilesAttach(inputs: [AdminTaxFileAttachInput!]!): MutationResult!
    adminTaxFilesUpsert(inputs: [AdminTaxFileUpsert!]!): MutationResult!
    adminTaxFilesDelete(taxFileIds: [ID!]!): MutationResult!
}
