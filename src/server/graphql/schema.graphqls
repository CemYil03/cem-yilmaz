scalar DateTime
scalar Date
# Untyped JSON payload — used only where the GraphQL schema is itself a union
# of values that the UI surfaces verbatim (e.g. tool call arguments rendered
# in a debug/inspect dialog). See docs/architecture/chat.md.
scalar JSON

type ChatMessageUser {
    chatMessageId: ID!
    # Null for anonymous visitor messages. The visitor surface never has a
    # `User` row to attach (anonymous traffic by design) — the client
    # renders "Du" / "You" when this is null. Admin chats always have a
    # logged-in author so the field is populated there.
    author: User
    body: String!
    # Files the user attached to this message, in send-order. Empty list when
    # the message was a plain-text send. The bytes are not exposed inline —
    # `FileUpload.url` points at `/api/file-uploads/:id` which streams them
    # back behind the same session cookie that authorized the upload.
    attachments: [FileUpload!]!
    # Observations the profile analyzer extracted from this user message.
    # Empty when the analyzer hasn't run yet, or ran and found nothing to
    # record. Populated only on admin (`scope = 'admin'`) chats — the
    # analyzer never runs on visitor messages. The UI uses this to render an
    # inline "N observations" pill below the message body. See
    # `docs/features/profile.md`.
    profileObservations: [ProfileObservation!]!
    createdAt: DateTime!
}

# A persisted user-uploaded file. Consumer-agnostic — chat surfaces these
# today as message attachments via the `ChatMessageUser.attachments` field,
# but the same shape is reused by other surfaces (e.g. assistant-side
# outputs, avatars, document uploads).
type FileUpload {
    fileUploadId: ID!
    filename: String!
    # IANA media type — drives both the in-bubble preview (image vs file
    # chip) and the LLM-side `ImagePart` / `FilePart` choice in
    # `toModelMessages`.
    mediaType: String!
    # Size in bytes. Mirrors what the upload route persisted; clamped at the
    # route, not validated again here.
    size: Int!
    # Server-rooted URL to stream the bytes back. Today: `/api/file-uploads/:id`.
    url: String!
}

# Snapshot of a single LLM step's identity and token usage. Attached to every
# AI-produced message variant — see `docs/architecture/chat-persistence.md`
# ("Generation metadata"). The whole field is nullable on the parent variants
# because pre-feature rows have no usage and rare provider responses may omit
# the model id; when present, `modelId` is always populated. The token fields
# are individually nullable because providers vary (Gemini reports
# `cachedInputTokens`; OpenAI reports `reasoningTokens`; some omit
# `totalTokens` and the server falls back to `inputTokens + outputTokens`).
#
# A single LLM step can produce multiple message rows (text + N tool calls);
# each row carries the same snapshot, so naive `SUM(totalTokens)` aggregations
# over-count. Group by `(chatMessageId, step boundary)` for accurate totals.
type ChatMessageGeneration {
    modelId: String!
    inputTokens: Int
    outputTokens: Int
    totalTokens: Int
    reasoningTokens: Int
    cachedInputTokens: Int
}

type ChatMessageAssistantText {
    chatMessageId: ID!
    body: String!
    # Snapshot of the LLM step that produced this row. See `ChatMessageGeneration`.
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

type ChatMessageToolCall {
    chatMessageId: ID!
    toolName: String!
    # Per-tool-typed call arguments, exposed as opaque JSON so the UI can
    # render them in an inspect dialog. The shape is only validated at the
    # tool boundary by Zod.
    args: JSON!
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

type ChatMessageToolApprovalRequest {
    chatMessageId: ID!
    approvalId: String!
    toolName: String!
    # The pending call's arguments — same shape and rationale as
    # `ChatMessageToolCall.args`. Surfaced so the human can inspect what the
    # assistant is asking permission to run before approving.
    args: JSON!
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

type ChatMessageToolApprovalResponse {
    chatMessageId: ID!
    approvalId: String!
    approved: Boolean!
    # Optional free-text justification the human typed when responding. The
    # SDK's `ToolApprovalResponse` carries this through to the synthetic
    # denied tool-result so the LLM sees *why* a call was declined.
    reason: String
    createdAt: DateTime!
}

# --- Assistant input collection ----------------------------------------------
#
# A single assistant turn that asks the user for one or more structured values.
# Each entry in `inputs` is a typed slot — see `union ChatAssistantInput`.
# The user's response is a single `ChatMessageUserInput` carrying one
# `ChatMessageUserInputAnswer` per answered slot (all-or-nothing submit).

type ChatMessageAssistantInputCollection {
    chatMessageId: ID!
    prompt: String!
    inputs: [ChatAssistantInput!]!
    # `Form` renders every slot at once; `StepThrough` walks the user through
    # one slot at a time. The submitted answer set is identical between modes —
    # the wizard accumulates drafts client-side and submits the same batch the
    # form does. Picked by the LLM via the `promptUserForInput` tool's `mode`
    # input; defaults to `Form`.
    #
    # Plain `String!` (not a GraphQL enum) so the typescript-operations
    # codegen plugin doesn't re-emit a duplicate type alias next to the one
    # the typescript plugin already emits. Same workaround the inlined
    # mutations use for named input types — see chat.md.
    mode: String!
    generation: ChatMessageGeneration
    createdAt: DateTime!
}

union ChatAssistantInput =
    | ChatAssistantInputDate
    | ChatAssistantInputDateRange
    | ChatAssistantInputDateTime
    | ChatAssistantInputTime
    | ChatAssistantInputSingleSelect
    | ChatAssistantInputMultiSelect
    | ChatAssistantInputBoolean
    | ChatAssistantInputText
    | ChatAssistantInputOtp

type ChatAssistantInputDate {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputDateRange {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputDateTime {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputTime {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputSingleSelect {
    inputId: ID!
    prompt: String!
    options: [String!]!
}

type ChatAssistantInputMultiSelect {
    inputId: ID!
    prompt: String!
    options: [String!]!
}

type ChatAssistantInputBoolean {
    inputId: ID!
    prompt: String!
}

type ChatAssistantInputText {
    inputId: ID!
    prompt: String!
}

# Six-digit one-time code. Wire-shape is identical to `ChatAssistantInputText`
# (the answer is a `ChatAssistantInputValueString`), but the slot kind is
# distinct so the UI can render the six-box `<InputOTP>` component instead of
# a free-text field. Used exclusively by the visitor chat after
# `submitProjectRequest` to verify ownership of the supplied email address —
# see `docs/features/project-requests.md`.
type ChatAssistantInputOtp {
    inputId: ID!
    prompt: String!
}

# --- User response to an assistant input collection --------------------------

type ChatMessageUserInput {
    chatMessageId: ID!
    # Null for anonymous visitor responses — same rationale as
    # `ChatMessageUser.author`.
    author: User
    collectionMessageId: ID!
    # Real submits carry one entry per answered slot; an empty list signals
    # the row is protocol-only — written by `chatMessageCreate` to close an
    # open collection when the user sent a free-text message instead of
    # filling the form. See "Pivoting away from an open collection" in
    # docs/architecture/chat.md.
    answers: [ChatMessageUserInputAnswer!]!
    createdAt: DateTime!
}

type ChatMessageUserInputAnswer {
    inputId: ID!
    value: ChatAssistantInputValue!
}

union ChatAssistantInputValue =
    | ChatAssistantInputValueDate
    | ChatAssistantInputValueDateRange
    | ChatAssistantInputValueDateTime
    | ChatAssistantInputValueTime
    | ChatAssistantInputValueString
    | ChatAssistantInputValueStringList
    | ChatAssistantInputValueBoolean

type ChatAssistantInputValueDate {
    date: Date!
}

type ChatAssistantInputValueDateRange {
    from: Date!
    to: Date!
}

type ChatAssistantInputValueDateTime {
    dateTime: DateTime!
}

type ChatAssistantInputValueTime {
    # ISO 8601 local time, e.g. "14:30"
    time: String!
}

type ChatAssistantInputValueString {
    value: String!
}

type ChatAssistantInputValueStringList {
    values: [String!]!
}

type ChatAssistantInputValueBoolean {
    boolean: Boolean!
}

# --- Top-level chat message union --------------------------------------------

union ChatMessage =
    | ChatMessageUser
    | ChatMessageUserInput
    | ChatMessageAssistantText
    | ChatMessageToolCall
    | ChatMessageToolApprovalRequest
    | ChatMessageToolApprovalResponse
    | ChatMessageAssistantInputCollection

type Chat {
    chatId: ID!
    title: String!
    lastModifiedAt: DateTime!
    # Flat insertion-ordered list. Day-grouping is a render-time concern in the
    # client (the live `chatUpdates` subscription delivers raw messages, so the
    # client has to be the grouping authority anyway).
    messages: [ChatMessage!]!
}

input UserCreate {
    name: String!
}

input UserUpdate {
    name: String!
}

type User {
    userId: ID!
    name: String!
}

type Session {
    sessionId: ID!
    user: User
    # Visitor-assistant chats owned by this session, most-recent first. Empty
    # for sessions that have never started a visitor chat. The `messages`
    # field on each entry is empty — fetch a single chat through `Query.chat`
    # to materialize its transcript. Used by the chat dialog's empty state
    # so a returning visitor can resume a prior conversation.
    visitorChats: [Chat!]!
    # Rolling-24h cap on visitor-chat user messages from this requester.
    # Counted across (this session) OR (other sessions sharing this `ipHash`)
    # so clearing cookies does not reset the bucket. The visitor dialog
    # renders `used / limit` and the time until the oldest in-window message
    # ages out. See `docs/features/chat-visitor.md`.
    visitorChatQuota: VisitorChatQuota!
}

# Read-only quota snapshot. `resetsAt` is the moment the oldest in-window
# message ages out of the rolling 24h window — null when `used = 0`. Counts
# only user messages on `scope = 'public'` chats; admin chats are not
# counted. See `docs/features/chat-visitor.md`.
type VisitorChatQuota {
    used: Int!
    limit: Int!
    resetsAt: DateTime
}

type MutationResult {
    success: Boolean!
    referenceId: ID
}

type ChatMessageCreateResult {
    chatId: ID!
    chatMessageId: ID!
}

type UserMutation {
    userUpdate(user: UserUpdate!): MutationResult!
    terminateSessions(sessionIds: [ID!]!): MutationResult!
}

# --- User-input answer write shape -------------------------------------------
#
# GraphQL has no input unions, so we follow the same flat-discriminator pattern
# the `promptUserForInput` Zod tool schema uses: a `kind` enum drives which of
# the optional fields is read. The resolver validates the populated field
# matches `kind` and rejects mismatches before persistence.

enum ChatAssistantInputValueKind {
    Date
    DateRange
    DateTime
    Time
    String
    StringList
    Boolean
}

input ChatMessageUserInputAnswerCreate {
    inputId: ID!
    kind: ChatAssistantInputValueKind!
    date: Date
    dateRangeFrom: Date
    dateRangeTo: Date
    dateTime: DateTime
    time: String
    string: String
    stringList: [String!]
    boolean: Boolean
}

input ChatAssistantOptions {
    generationId: ID
    requireToolCallApprovals: Boolean!
}

type Query {
    currentSession: Session!
    # A single visitor chat by id. Resolves only `scope = 'public'` chats —
    # admin reads use `Query.admin.chat(...)` instead. See
    # `docs/architecture/multi-agent-chat.md`.
    chat(chatId: ID!): Chat!
    # Public CV namespace — surfaces the timeline (`/cv`) and the
    # skill/hobby blocks (`/about`). Always returns lists ordered by their
    # `position` column, ascending. Edits land via the admin namespace
    # (`Mutation.admin.cv*`), gated by `guardAdminMutation`. See
    # `docs/features/cv.md`.
    cv: CvQuery!
    # Workspace-only namespace, gated by `guardAdmin`. Visitor sessions get
    # an authorization error here.
    admin: Admin!
}

# Workspace read namespace — Cem's own chats and a separate window onto the
# visitor chats his site recorded. The split exists because the two have
# different agents, different system prompts, and different on-row tools; the
# `Chat` type itself is the same.
type Admin {
    # Visitor (`scope = 'public'`) chats, newest first.
    publicChats: [Chat!]!
    # A single visitor chat by id. Rejects `scope = 'admin'` chats.
    publicChat(chatId: ID!): Chat!
    # Admin (`scope = 'admin'`) chats, newest first.
    chats: [Chat!]!
    # A single admin chat by id. Rejects `scope = 'public'` chats.
    chat(chatId: ID!): Chat!
    # The AI-built profile of Cem. Reads three synthesized text artifacts
    # (`summary`, `prose`, `psychProfile`) plus the underlying observations
    # the analyzer extracted from admin chats. The `summary` field is the
    # only piece fed back into the personal-assistant system prompt; the
    # rest is read-only insight surfaced at `/workspace/profile`. See
    # `docs/features/profile.md`.
    profile: AdminProfile!
}

# Profile artifacts surfaced at `/workspace/profile`. Three text fields
# produced by the synthesizer plus a list-and-count view onto the underlying
# observations.
#
# Firewall: the resolver behind `summary` is the SAME row the analyzer reads
# into the assistant prompt — by design. `prose` and `psychProfile` are
# surfaced ONLY through this namespace and are never injected anywhere.
type AdminProfile {
    # Short factual summary (≤ ~500 tokens), used as system-prompt context for
    # admin chats. Empty until the first synthesis.
    summary: String!
    # Long-form, human-readable profile. Read by Cem on /workspace/profile.
    prose: String!
    # Psychological synthesis. NEVER fed back to any agent.
    psychProfile: String!
    # Null until the synthesizer has run at least once.
    synthesizedAt: DateTime
    # Model id that produced the latest synthesis. Surfaced as a faint
    # subtitle next to the timestamp so Cem knows which LLM generated the
    # text he is reading.
    synthesisModelId: String
    # Non-dismissed observations recorded since the last synthesis. Drives
    # the "Synthesize now" CTA's badge ("12 new observations").
    observationsSinceSynthesis: Int!
    # Observations, newest first. `category` filters server-side; `dismissed`
    # toggles between active rows (default, null = active only),
    # `dismissed: true` shows dismissed rows, `dismissed` omitted with
    # `includeDismissed: true` shows both.
    observations(category: ProfileObservationCategory, includeDismissed: Boolean): [ProfileObservation!]!
}

enum ProfileObservationCategory {
    factual
    behavioral
    psychological
}

# One row produced by the analyzer per admin user-message that revealed
# something new. `sourceChatMessage` is the user message it came from — null
# only if that message has since been deleted.
type ProfileObservation {
    observationId: ID!
    category: ProfileObservationCategory!
    content: String!
    # 0..100 (percent) confidence the analyzer reported. Null when the
    # analyzer omitted the field. The UI renders this as a faint dot row.
    confidence: Int
    analyzerModelId: String
    # Source message this observation was derived from. Null only when the
    # message has been deleted since (the observation outlives the message —
    # the synthesizer has already absorbed it).
    sourceChatMessageId: ID
    sourceChatId: ID
    # `null` while active, set on dismiss. Dismissed observations are
    # excluded from synthesis input but kept as an audit trail.
    dismissedAt: DateTime
    createdAt: DateTime!
}

type Mutation {
    userCreate(user: UserCreate!): MutationResult!
    user: UserMutation!
    # --- Visitor chat ---------------------------------------------------------
    # The three mutations below operate on `scope = 'public'` chats and
    # dispatch to the visitor agent (`agentVisitorAboutCem`). The agent
    # factory is selected by the access path — the resolver wires it in;
    # callers do NOT pass it. Mismatched scope (e.g. an admin chatId reaching
    # this namespace) is rejected by the command.
    chatMessageCreate(chatId: ID, message: String!, fileUploadIds: [ID!], assistantOptions: ChatAssistantOptions!): ChatMessageCreateResult
    chatInputCollectionRespond(
        collectionMessageId: ID!
        answers: [ChatMessageUserInputAnswerCreate!]!
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
    chatToolApprovalRespond(
        approvalId: String!
        approved: Boolean!
        reason: String
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
    # Workspace-only mutations, gated by `guardAdmin`.
    admin: AdminMutation!
}

# Workspace write namespace — same chat shape as the visitor mutations above,
# routed to `agentPersonalAssistant` and operating on `scope = 'admin'` chats.
type AdminMutation {
    chatMessageCreate(chatId: ID, message: String!, fileUploadIds: [ID!], assistantOptions: ChatAssistantOptions!): ChatMessageCreateResult
    chatInputCollectionRespond(
        collectionMessageId: ID!
        answers: [ChatMessageUserInputAnswerCreate!]!
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
    chatToolApprovalRespond(
        approvalId: String!
        approved: Boolean!
        reason: String
        assistantOptions: ChatAssistantOptions!
    ): ChatMessageCreateResult
}

# --- Chat live updates -------------------------------------------------------
#
# A single subscription that delivers every event of an in-flight assistant
# turn — newly persisted `ChatMessage` rows (user message, tool call, approval
# request/response, input collection, final assistant text) and assistant-text
# deltas during streaming. Keyed by an ephemeral, client-allocated
# `generationId` (UUIDv4); the unguessable id IS the capability today. Real
# chat-level authorization will layer on once chats grow user ownership.
#
# `ChatUpdateAssistantTextChunk.chatMessageId` is pre-allocated server-side
# before streaming begins; it equals the id of the eventual
# `ChatMessageAssistantText` row that arrives as `ChatUpdateMessageAppended`
# at end-of-stream. Clients use it to swap their in-place streaming row for
# the persisted message with no layout shift.

type ChatUpdateMessageAppended {
    message: ChatMessage!
}

type ChatUpdateAssistantTextChunk {
    chatMessageId: ID!
    delta: String!
}

# Marker variant published exactly once per turn — when `chatAssistantTurnRun`
# exits (success or failure). Lets the client tear down per-turn state
# (composer lock, active streamingId) without waiting on the mutation that
# kicked the turn off, since the mutation now returns as soon as the user-side
# row is committed and the agent runs detached.
type ChatUpdateTurnEnded {
    generationId: ID!
}

union ChatUpdate = ChatUpdateMessageAppended | ChatUpdateAssistantTextChunk | ChatUpdateTurnEnded

type Subscription {
    userUpdates: User!
    chatUpdates(generationId: ID!): ChatUpdate!
}

# --- CV ----------------------------------------------------------------------
#
# Editable CV content surfaced on `/cv` and `/about`. Bilingual text rides
# as paired `*De` / `*En` fields — the client renders the locale-matching
# pair. `position` is server-authoritative ordering written by `*Reorder`.
# See `docs/features/cv.md`.

type CvExperience {
    cvExperienceId: ID!
    roleDe: String!
    roleEn: String!
    companyDe: String!
    companyEn: String!
    # ISO 8601 calendar date (yyyy-mm-dd).
    startDate: Date!
    # Null marks an ongoing role. The renderer formats it as "heute" / "today".
    endDate: Date
    descriptionDe: String!
    descriptionEn: String!
    technologies: [String!]!
    managerName: String
    position: Int!
}

type CvEducation {
    cvEducationId: ID!
    degreeDe: String!
    degreeEn: String!
    institutionDe: String!
    institutionEn: String!
    # Optional course of study within the degree (e.g. "Informatik").
    subjectDe: String!
    subjectEn: String!
    # Education entries occasionally have only an end date (e.g. Abitur).
    startDate: Date
    endDate: Date!
    # Free-form notes per locale: "Kursprecher", "Abschlussprüfung Informatik: 1+", etc.
    notesDe: String!
    notesEn: String!
    position: Int!
}

# `category` is a flat enum — see the CvSkillCategory definition. Skill
# labels themselves are not translated.
type CvSkill {
    cvSkillId: ID!
    category: CvSkillCategory!
    label: String!
    position: Int!
}

enum CvSkillCategory {
    capabilities
    frameworks
    services
    tools
    languages
}

type CvHobby {
    cvHobbyId: ID!
    textDe: String!
    textEn: String!
    # Optional anchor year for entries like "Seit 2011 Karate".
    since: Int
    position: Int!
}

type CvQuery {
    experience: [CvExperience!]!
    education: [CvEducation!]!
    skills: [CvSkill!]!
    hobbies: [CvHobby!]!
}

# --- CV admin write inputs ---------------------------------------------------
#
# Upserts use a nullable id: when present the row with that id is updated,
# when absent a new row is created. The `position` slot lets the editor
# place a new row at a specific spot; reordering as a whole is a separate
# `*Reorder` mutation that takes the full id array.

input CvExperienceInput {
    cvExperienceId: ID
    roleDe: String!
    roleEn: String!
    companyDe: String!
    companyEn: String!
    startDate: Date!
    endDate: Date
    descriptionDe: String!
    descriptionEn: String!
    technologies: [String!]!
    managerName: String
    position: Int!
}

input CvEducationInput {
    cvEducationId: ID
    degreeDe: String!
    degreeEn: String!
    institutionDe: String!
    institutionEn: String!
    subjectDe: String!
    subjectEn: String!
    startDate: Date
    endDate: Date!
    notesDe: String!
    notesEn: String!
    position: Int!
}

input CvSkillInput {
    cvSkillId: ID
    category: CvSkillCategory!
    label: String!
    position: Int!
}

input CvHobbyInput {
    cvHobbyId: ID
    textDe: String!
    textEn: String!
    since: Int
    position: Int!
}

# --- Projects, Tasks, Project requests ---------------------------------------
#
# Workspace projects surface: incoming visitor `ProjectRequest`s plus
# admin-only `Project` and `Task` rows. Single-language (no `*De` / `*En`
# pairs — never surfaced publicly). See `docs/features/projects-workspace.md`.

enum ProjectRequestStatus {
    pendingOtp
    emailVerified
    archived
}

enum ProjectRequestType {
    webApp
    mobile
    consulting
    aiIntegration
    other
}

# A visitor-submitted project brief. Surfaced on the workspace projects
# Inbox tab once `status = emailVerified`. The `otpHash` / `otpSalt`
# columns are deliberately not exposed — the GraphQL surface is read-only
# triage, not OTP introspection.
type ProjectRequest {
    projectRequestId: ID!
    chatId: ID
    name: String!
    email: String!
    company: String
    projectType: ProjectRequestType!
    description: String!
    budget: String
    timeline: String
    status: ProjectRequestStatus!
    verifiedAt: DateTime
    createdAt: DateTime!
    updatedAt: DateTime!
    # Project this request was converted into, if any. Lets the Inbox row
    # render a "Converted →" backlink. Set when `projectUpsert` creates a
    # project with `sourceRequestId` pointing at this row; null otherwise.
    convertedProject: Project
}

enum ProjectStatus {
    idea
    planning
    active
    paused
    done
    archived
}

type Project {
    projectId: ID!
    title: String!
    description: String
    notes: String
    status: ProjectStatus!
    position: Int!
    # Source visitor request this project was created from, when applicable.
    # Null for hand-created projects.
    sourceRequest: ProjectRequest
    startedAt: DateTime
    completedAt: DateTime
    createdAt: DateTime!
    updatedAt: DateTime!
    # Project-bound tasks, ordered by `position` within their status bucket.
    tasks: [Task!]!
    # Timeline of events and work sessions, newest first.
    activities: [ProjectActivity!]!
    # Sum of `durationSec` across `kind = work` activities, in seconds.
    # Zero when no timer has ever run against the project.
    totalWorkSec: Int!
}

enum TaskStatus {
    todo
    doing
    done
}

type Task {
    taskId: ID!
    # Owning project. Null = standalone todo (surfaced on the Todos tab).
    projectId: ID
    title: String!
    notes: String
    status: TaskStatus!
    position: Int!
    dueAt: DateTime
    completedAt: DateTime
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Categorizes an entry on the project timeline. `clientContact` and
# `meeting` carry a `channel`; the others omit it.
enum ProjectActivityKind {
    clientContact
    meeting
    work
    offer
    milestone
    note
}

# How the contact / meeting happened. Only meaningful on
# `clientContact` / `meeting` rows.
enum ProjectActivityChannel {
    malt
    email
    phone
    videoCall
    inPerson
    aiAssistant
    other
}

# A single entry on a project's timeline. Covers both logged events
# (call, email, offer sent) and timed work sessions — the latter populate
# `startedAt` / `endedAt` and have `kind = work`.
type ProjectActivity {
    activityId: ID!
    projectId: ID!
    # Optional task this activity is attached to. Lets totals roll up per
    # task without forcing every activity to pick one.
    taskId: ID
    kind: ProjectActivityKind!
    channel: ProjectActivityChannel
    title: String!
    notes: String
    # When the event happened. Equals `startedAt` on timer rows.
    occurredAt: DateTime!
    # Set on work-timer rows; null on event rows.
    startedAt: DateTime
    # Null while a timer is running.
    endedAt: DateTime
    # Cached `endedAt - startedAt` in seconds. Settable directly on event
    # rows ("the call was 45 min") without running a timer.
    durationSec: Int
    createdAt: DateTime!
    updatedAt: DateTime!
}

# Workspace projects read namespace — mounted under `Admin.projects` so
# the existing `guardAdmin` gate covers it.
extend type Admin {
    # Incoming visitor project briefs, newest first. The `status` argument
    # filters server-side; omit to return every state (including the
    # half-baked `pendingOtp` rows, mostly useful for debugging).
    projectRequests(status: ProjectRequestStatus): [ProjectRequest!]!
    # Lightweight count of verified-and-untriaged requests. Drives the
    # inbox badge on the workspace hub. Equivalent to
    # `projectRequests(status: emailVerified)` minus rows already
    # converted into a project — but a single `count(*)` round-trip
    # instead of materialising every row + its join.
    projectRequestsInboxCount: Int!
    # All projects, ordered by status then `position`. The board groups
    # client-side by status. `status` argument narrows server-side when set.
    projects(status: ProjectStatus): [Project!]!
    # Standalone todos: rows with `projectId IS NULL`. Project-bound tasks
    # are reached through `Project.tasks` so the Todos tab and the project
    # board don't fight over the same list.
    standaloneTasks: [Task!]!
    # The single currently-running work timer, or null if none. Drives the
    # header badge and per-project timer pill. At most one row exists with
    # `endedAt IS NULL AND kind = 'work'` — the DB enforces this via a
    # partial unique index.
    activeTimer: ProjectActivity
}

input ProjectCreate {
    projectId: ID
    title: String!
    description: String
    notes: String
    status: ProjectStatus!
    # Optional on create — when omitted, the server appends the new row to
    # the end of the `planning` column (max(position) + 1). Required on
    # update; the editor always knows the board state and passes it back.
    position: Int
    # When set on a create, the new project is the conversion of an
    # `emailVerified` `ProjectRequest`. `projectUpsert` validates the
    # request is in that state and archives it in the same transaction
    # as the project insert. Ignored on update.
    sourceRequestId: ID
    startedAt: DateTime
    completedAt: DateTime
}

input TaskCreate {
    taskId: ID
    projectId: ID
    title: String!
    notes: String
    status: TaskStatus!
    position: Int!
    dueAt: DateTime
    completedAt: DateTime
}

# Activity create / update payload. `activityId` toggles upsert mode.
# Server validates that `channel` is set only when `kind` is
# `clientContact` or `meeting`. For event rows leave `startedAt` /
# `endedAt` null; the timer mutations write those columns directly.
input ProjectActivityCreate {
    activityId: ID
    projectId: ID!
    taskId: ID
    kind: ProjectActivityKind!
    channel: ProjectActivityChannel
    title: String!
    notes: String
    occurredAt: DateTime!
    durationSec: Int
}

# CV admin namespace — mounted under `AdminMutation.cv` so the existing
# `guardAdminMutation` gate covers it without a parallel Mutation entry.
extend type AdminMutation {
    cvExperienceUpsert(input: CvExperienceInput!): CvExperience!
    cvExperienceDelete(cvExperienceId: ID!): MutationResult!
    cvExperienceReorder(orderedIds: [ID!]!): MutationResult!
    cvEducationUpsert(input: CvEducationInput!): CvEducation!
    cvEducationDelete(cvEducationId: ID!): MutationResult!
    cvEducationReorder(orderedIds: [ID!]!): MutationResult!
    cvSkillUpsert(input: CvSkillInput!): CvSkill!
    cvSkillDelete(cvSkillId: ID!): MutationResult!
    cvSkillReorder(orderedIds: [ID!]!): MutationResult!
    cvHobbyUpsert(input: CvHobbyInput!): CvHobby!
    cvHobbyDelete(cvHobbyId: ID!): MutationResult!
    cvHobbyReorder(orderedIds: [ID!]!): MutationResult!
    # Soft-dismiss an observation. The row stays in the DB but is excluded
    # from the synthesizer's input. A future "undismiss" mutation could clear
    # `dismissedAt`; today the page treats dismiss as final but reversible by
    # a re-run of the synthesizer over the older data.
    profileObservationDismiss(observationId: ID!): MutationResult!
    # Force a synthesis pass now. Enqueues the `profileSynthesize` job. The
    # job updates the `Profile` row and resets `observationsSinceSynthesis`.
    profileSynthesizeRequest: MutationResult!
    # --- Workspace projects -------------------------------------------------
    # Archive an incoming request without converting it to a project. Flips
    # `status = archived` so the Inbox tab can hide it by default.
    projectRequestArchive(projectRequestId: ID!): MutationResult!
    # Permanent delete. Use for spam that survived OTP verification.
    projectRequestDelete(projectRequestId: ID!): MutationResult!
    # Create or update a project. Conversion of a verified `ProjectRequest`
    # is the same call with `sourceRequestId` set on a create — the server
    # validates the request is `emailVerified`, links the new project to
    # it, and archives the request in the same transaction.
    projectUpsert(input: ProjectCreate!): Project!
    projectDelete(projectId: ID!): MutationResult!
    projectReorder(orderedIds: [ID!]!): MutationResult!
    taskUpsert(input: TaskCreate!): Task!
    taskDelete(taskId: ID!): MutationResult!
    # Rewrite `position` on the given task ids in array order. Caller scopes
    # the list to a single `(projectId, status)` bucket — the server does
    # not enforce membership in one bucket, but mixing buckets in one call
    # is meaningless.
    taskReorder(orderedIds: [ID!]!): MutationResult!
    # --- Project activities & timer ----------------------------------------
    # Create or update an activity row (call logged, email sent, offer
    # drafted, freeform note). `kind = work` rows are reserved for the
    # timer mutations and rejected here.
    projectActivityUpsert(input: ProjectActivityCreate!): ProjectActivity!
    projectActivityDelete(activityId: ID!): MutationResult!
    # Start a work timer on the given project. Atomically stops the
    # currently-running timer (if any) before inserting the new row, so
    # the one-active-timer invariant holds even across rapid taps.
    # `title` defaults to "Work session" when omitted.
    projectTimerStart(projectId: ID!, taskId: ID, title: String): ProjectActivity!
    # Stamp `endedAt = now` and write `durationSec` on the running timer.
    # Idempotent on an already-stopped row — returns the row untouched.
    projectTimerStop(activityId: ID!): ProjectActivity!
}
