# Integration-test environment variables.
#
# Copy this file to .env.test and fill in a real value. .env.test is
# gitignored.
#
# Loaded by src/server/test/commandTestUtils.ts (via dotenv) before
# integration tests run. Unit tests do NOT depend on this file — they pass
# an explicit source object to environmentVariablesCreate(). Only the
# command/integration tests that hit a real Postgres need the value below.
#
# Use a SEPARATE database from .env.local — tests truncate and mutate
# freely.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mydb_test"

# Salt for the visitor-chat IP-hash bucket. Required at env construction
# time even though tests rarely exercise sessionUpsert with a real IP. Any
# non-empty string works for tests — production uses `openssl rand -hex 32`.
VISITOR_IP_HASH_SALT="test-salt"
